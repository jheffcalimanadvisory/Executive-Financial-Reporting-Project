table GL_Actual
	lineageTag: 8733945c-019b-4663-b16c-129614b4d22f

	measure 'Sum of BudgetAmount % difference from Sum of Amount' =
			
			VAR __BASELINE_VALUE = SUM('GL_Actual'[Amount])
			VAR __VALUE_TO_COMPARE = SUM('GL_Budget'[BudgetAmount])
			RETURN
				IF(
					NOT ISBLANK(__VALUE_TO_COMPARE),
					DIVIDE(__VALUE_TO_COMPARE - __BASELINE_VALUE, __BASELINE_VALUE)
				)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 9e6e841c-1e18-4ba6-862e-0ec87ed00362

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "MathematicalPercentageDifference"
				}

		changedProperty = FormatString

	column PostingDate
		dataType: dateTime
		formatString: Long Date
		lineageTag: 03700348-325e-49cc-aeb9-a55ca7a95fe7
		summarizeBy: none
		sourceColumn: PostingDate

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

