	partition GL_Actual = m
		mode: import
		source =
				let
				    Source = Excel.Workbook(File.Contents("C:\Power BI\Financial Statements\Enterprise_GL_Model_IT01_2025.xlsx"), null, true),
				    GL_Actual_Sheet = Source{[Item="GL_Actual",Kind="Sheet"]}[Data],
				    #"Promoted Headers" = Table.PromoteHeaders(GL_Actual_Sheet, [PromoteAllScalars=true]),
