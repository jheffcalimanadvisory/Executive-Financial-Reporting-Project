/// Year-end BS snapshots per year. 330100=Current Year Result. Equation balances per year.
table Opening_Balances
	lineageTag: 774bb534-d9ca-41dd-971c-c040326426f8

	column OB_Date
		lineageTag: 0bdc9d4b-b59a-4085-b909-9c02d6d392c5
		summarizeBy: none
		isNameInferred
		sourceColumn: [OB_Date]

		variation Variation
			isDefault
			relationship: f579fe46-7975-42cc-a60a-585bcbfdf076
