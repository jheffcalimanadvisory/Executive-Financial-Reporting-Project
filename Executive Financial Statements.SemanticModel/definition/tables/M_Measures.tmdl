			VAR fs=SELECTEDVALUE(INCOME_Structure[FSGroup],"") VAR sub=SELECTEDVALUE(INCOME_Structure[FSSubgroup],"") VAR rl=SELECTEDVALUE(INCOME_Structure[RowLevel],"")
			VAR hasYearFilter=HASONEVALUE(Dim_Date[Year]) VAR yr=SELECTEDVALUE(Dim_Date[Year],0)
			
			VAR GroupSums = CALCULATETABLE(ADDCOLUMNS(VALUES(Dim_Accounts[FSGroup]), "@Amt", [Actual]), ALL(Dim_Date), IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()))
			
			VAR vR=SUMX(FILTER(GroupSums,[FSGroup]="Revenue"),[@Amt])
			VAR vDedRaw=SUMX(FILTER(GroupSums,[FSGroup]="Deductions"),[@Amt])
			VAR vDed=IF(ISBLANK(vDedRaw),0,ABS(vDedRaw))
			VAR vC=SUMX(FILTER(GroupSums,[FSGroup]="COGS"),[@Amt])
			VAR vO=SUMX(FILTER(GroupSums,[FSGroup]="Operating Expenses"),[@Amt])
			VAR vD=SUMX(FILTER(GroupSums,[FSGroup]="D&A"),[@Amt])
			VAR vFinIncome=ABS(CALCULATE([Actual], ALL(Dim_Date), IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Income"))
			VAR vFinExpense=ABS(CALCULATE([Actual], ALL(Dim_Date), IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Expenses"))
			VAR vF=vFinIncome-vFinExpense
			VAR vT=SUMX(FILTER(GroupSums,[FSGroup]="Taxes"),[@Amt])
			
			VAR DetailAmt = CALCULATE([Actual], ALL(Dim_Date), IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Accounts[FSGroup]=fs, Dim_Accounts[FSSubgroup]=sub)
			
			VAR raw = SWITCH(TRUE(),
			    rl="Header",0,
			    fs="Revenue"&&rl="Detail",vR,
			    fs="Deductions",vDed,
			    fs="Net Revenue",vR-vDed,
			    fs="COGS"&&rl="Detail",DetailAmt,
			    fs="COGS Total",vC,
			    fs="Gross Profit",vR-vDed-vC,
			    fs="Operating Expenses"&&rl="Detail",DetailAmt,
			    fs="OPEX Total",vO,
			    fs="EBITDA",vR-vDed-vC-vO,
			    fs="D&A"&&rl="Detail",vD,
			    fs="EBIT",vR-vDed-vC-vO-vD,
			    fs="Financial Result"&&rl="Detail",DetailAmt,
			    fs="EBT",vR-vDed-vC-vO-vD+vF,
			    fs="Taxes"&&rl="Detail",vT,
			    fs="Net Income",vR-vDed-vC-vO-vD+vF-vT,
			    BLANK())
			RETURN IF(fs IN {"COGS","Operating Expenses","D&A","Taxes","Financial Result"} && rl="Detail", ABS(raw), raw)
		formatString: 0
		isHidden
		displayFolder: Income Statement\_Base
		lineageTag: 44696baa-8b65-4a58-9892-81b6914ef888

	/// For the current open year (dynamically = Forecast_BaseYear), FY Budget is now capped at the last actual month (e.g. Jan-Apr 2026) instead of the full 12-month budget, so it stays comparable to FY Actual which is naturally truncated by having no future postings. Prior closed years are unaffected (full 12-month budget). Adds one extra Month Number<=MonthCap filter to the existing calls - no new storage-engine queries.
	measure Base_FY_B =
			VAR fs=SELECTEDVALUE(INCOME_Structure[FSGroup],"") VAR sub=SELECTEDVALUE(INCOME_Structure[FSSubgroup],"") VAR rl=SELECTEDVALUE(INCOME_Structure[RowLevel],"")
			VAR hasYearFilter=HASONEVALUE(Dim_Date[Year]) VAR yr=SELECTEDVALUE(Dim_Date[Year],0)
			VAR BaseYr=[Forecast_BaseYear]
			VAR LastMo=CALCULATE([IS_LastMonth], ALL(Dim_Date), Dim_Date[Year]=BaseYr)
			VAR MonthCap=IF(hasYearFilter && yr=BaseYr, LastMo, 12)
			
			VAR GroupSums = CALCULATETABLE(ADDCOLUMNS(VALUES(Dim_Accounts[FSGroup]), "@Amt", [Budget]), ALL(Dim_Date), IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Date[Month Number]<=MonthCap)
			
			VAR vR=SUMX(FILTER(GroupSums,[FSGroup]="Revenue"),[@Amt])
			VAR vDedRaw=SUMX(FILTER(GroupSums,[FSGroup]="Deductions"),[@Amt])
			VAR vDed=IF(ISBLANK(vDedRaw),0,ABS(vDedRaw))
			VAR vC=SUMX(FILTER(GroupSums,[FSGroup]="COGS"),[@Amt])
			VAR vO=SUMX(FILTER(GroupSums,[FSGroup]="Operating Expenses"),[@Amt])
			VAR vD=SUMX(FILTER(GroupSums,[FSGroup]="D&A"),[@Amt])
			VAR vFinIncome=ABS(CALCULATE([Budget], ALL(Dim_Date), IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Date[Month Number]<=MonthCap, Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Income"))
			VAR vFinExpense=ABS(CALCULATE([Budget], ALL(Dim_Date), IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Date[Month Number]<=MonthCap, Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Expenses"))
			VAR vF=vFinIncome-vFinExpense
			VAR vT=SUMX(FILTER(GroupSums,[FSGroup]="Taxes"),[@Amt])
			
			VAR DetailAmt = CALCULATE([Budget], ALL(Dim_Date), IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Date[Month Number]<=MonthCap, Dim_Accounts[FSGroup]=fs, Dim_Accounts[FSSubgroup]=sub)
			
			VAR raw = SWITCH(TRUE(),
			    rl="Header",0,
			    fs="Revenue"&&rl="Detail",vR,
			    fs="Deductions",vDed,
			    fs="Net Revenue",vR-vDed,
			    fs="COGS"&&rl="Detail",DetailAmt,
			    fs="COGS Total",vC,
			    fs="Gross Profit",vR-vDed-vC,
			    fs="Operating Expenses"&&rl="Detail",DetailAmt,
			    fs="OPEX Total",vO,
			    fs="EBITDA",vR-vDed-vC-vO,
			    fs="D&A"&&rl="Detail",vD,
			    fs="EBIT",vR-vDed-vC-vO-vD,
			    fs="Financial Result"&&rl="Detail",DetailAmt,
			    fs="EBT",vR-vDed-vC-vO-vD+vF,
			    fs="Taxes"&&rl="Detail",vT,
			    fs="Net Income",vR-vDed-vC-vO-vD+vF-vT,
			    BLANK())
			RETURN IF(fs IN {"COGS","Operating Expenses","D&A","Taxes","Financial Result"} && rl="Detail", ABS(raw), raw)
		formatString: 0
		isHidden
		displayFolder: Income Statement\_Base
		lineageTag: 4372f0b9-71f8-4986-9611-aa4081fa258a

	/// Minimum cash target = 3x trailing 12-month average monthly OPEX (rolling coverage buffer). Assumption: no fixed covenant provided, using 3 months OPEX as a standard liquidity buffer.
	measure CF_MinCashTarget =
			VAR MaxDate=MAX(Dim_Date[Date])
			VAR Last12M=CALCULATE([IS_OPEX], DATESINPERIOD(Dim_Date[Date], MaxDate, -12, MONTH))
			RETURN DIVIDE(Last12M,12,0)*3
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow
		lineageTag: ecafbe3f-56f4-4202-8c02-1f27ccd21583

	/// Currency figures now formatted with explicit it-IT locale so the engine renders the group-separator token as a period (e.g. 3.565.247) per Italian convention, instead of defaulting to a comma.
	measure CF_Commentary =
			VAR OpCF=[CF_OperatingCF]
			VAR InvCF=[CF_InvestingCF]
			VAR Closing=[CF_ClosingCash]
			VAR MinTarget=[CF_MinCashTarget]
			VAR BelowTarget=Closing<MinTarget
			VAR CoveragePct=DIVIDE(OpCF,ABS(InvCF),BLANK())
			VAR BaseMsg =
			    SWITCH(TRUE(),
			        ISBLANK(InvCF) || InvCF=0, "No investing activity this period.",
			        OpCF<0, "Operations used " & FORMAT(ABS(OpCF),"€#,##0","it-IT") & " of cash this period, on top of " & FORMAT(ABS(InvCF),"€#,##0","it-IT") & " invested — both operating and investing activities are consuming cash.",
			        CoveragePct>=1, "Operating cash fully covers investing spend (" & FORMAT(CoveragePct,"0%") & ") — growth is largely self-funded.",
			        TRUE(), "Operating cash covers " & FORMAT(CoveragePct,"0%") & " of investing spend."
			    )
			RETURN
			IF(BelowTarget, "Cash balance is below the minimum target. " & BaseMsg, BaseMsg)
		displayFolder: Cash Flow
		lineageTag: 1dadd805-5a2a-4ad0-b15c-9bab362a397b

	/// Font color for Cash Coverage Ratio tile - red if below 2.0x target, green if healthy
	measure CF_CoverageColor =
			VAR v=[CF_CashCoverageRatio]
			RETURN IF(ISBLANK(v),"#FFFFFF",IF(v<2,"#FF4444","#4CAF50"))
		displayFolder: Cash Flow\Formatting
		lineageTag: 2f5ab7d6-721e-4e48-83c0-1773114dc38a

	/// Font/line color for Closing Cash vs minimum target - red if below target
	measure CF_CashTargetColor =
			VAR c=[CF_ClosingCash]
			VAR t=[CF_MinCashTarget]
			RETURN IF(ISBLANK(c)||ISBLANK(t),"#FFFFFF",IF(c<t,"#FF4444","#4CAF50"))
		displayFolder: Cash Flow\Formatting
		lineageTag: d42ef37e-b5aa-42c0-b32e-3072c9eb3df4

	/// Value for the Cash Bridge waterfall - one figure per CF_Structure bridge step (Opening/Operating/Investing/Financing/Closing)
	measure CF_BridgeValue =
			VAR grp=SELECTEDVALUE(CF_Structure[CFGroup],"")
			RETURN
			SWITCH(
			    TRUE(),
			    grp="Opening Cash Balance", [CF_OpeningCash],
			    grp="TOTAL OPERATING CF", [CF_OperatingCF],
			    grp="TOTAL INVESTING CF", [CF_InvestingCF],
			    grp="TOTAL FINANCING CF", [CF_FinancingCF],
			    grp="CLOSING CASH BALANCE", [CF_ClosingCash],
			    BLANK()
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow
		lineageTag: 829878da-e910-4567-b962-4bb3df82e2f0

	/// MATH FIX: was a naive lifetime cumulative SUM(GL_Actual[Amount]) with no opening-balance anchor - returned blank because prepaid postings net to ~zero over full history. Now reuses the already-correct, OB-anchored CF_AsOf_PrepaidExpenses (same fix pattern as BS_AccountsReceivable/BS_Inventory).
	measure BS_PrepaidExpenses = ABS([CF_AsOf_PrepaidExpenses])
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: 61a0ef51-5018-4217-a2cb-d12e66d3ae36

	/// Accounts Receivable balance as of selected date. FIXED: anchors to most recent OB snapshot <= MaxDate.
	measure CF_AsOf_AccountsReceivable =
			VAR MaxDate = MAX(Dim_Date[Date])
			VAR AnchorDate = CALCULATE(MAX(Opening_Balances[OB_Date]), FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] <= MaxDate && Opening_Balances[OB_Account] = 120100))
			VAR OB = IF(ISBLANK(AnchorDate), 0, SUMX(FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] = AnchorDate && Opening_Balances[OB_Account] = 120100), Opening_Balances[OB_Amount]))
			VAR GL_Movement = CALCULATE(SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date] <= MaxDate && (ISBLANK(AnchorDate) || Dim_Date[Date] > AnchorDate)), Dim_Accounts[Account] = "120100")
			RETURN OB + GL_Movement
		formatString: "€" #,0
		isHidden
		displayFolder: Cash Flow\_Base
		lineageTag: 340a07f5-ab0e-400a-9ed7-3b76d51976ff

	/// Inventory balance as of selected date. FIXED: anchors to most recent OB snapshot <= MaxDate.
	measure CF_AsOf_Inventory =
			VAR MaxDate = MAX(Dim_Date[Date])
			VAR AnchorDate = CALCULATE(MAX(Opening_Balances[OB_Date]), FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] <= MaxDate && Opening_Balances[OB_Account] = 120200))
			VAR OB = IF(ISBLANK(AnchorDate), 0, SUMX(FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] = AnchorDate && Opening_Balances[OB_Account] = 120200), Opening_Balances[OB_Amount]))
			VAR GL_Movement = CALCULATE(SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date] <= MaxDate && (ISBLANK(AnchorDate) || Dim_Date[Date] > AnchorDate)), Dim_Accounts[Account] = "120200")
			RETURN OB + GL_Movement
		formatString: "€" #,0
		isHidden
		displayFolder: Cash Flow\_Base
		lineageTag: e4797081-78b9-472b-9821-72989172fc7f

	/// Prepaid Expenses balance as of selected date. FIXED: anchors to most recent OB snapshot <= MaxDate.
	measure CF_AsOf_PrepaidExpenses =
			VAR MaxDate = MAX(Dim_Date[Date])
			VAR AnchorDate = CALCULATE(MAX(Opening_Balances[OB_Date]), FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] <= MaxDate && Opening_Balances[OB_Account] = 130100))
			VAR OB = IF(ISBLANK(AnchorDate), 0, SUMX(FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] = AnchorDate && Opening_Balances[OB_Account] = 130100), Opening_Balances[OB_Amount]))
			VAR GL_Movement = CALCULATE(SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date] <= MaxDate && (ISBLANK(AnchorDate) || Dim_Date[Date] > AnchorDate)), Dim_Accounts[Account] = "130100")
			RETURN OB + GL_Movement
		formatString: "€" #,0
		isHidden
		displayFolder: Cash Flow\_Base
		lineageTag: 54467c5c-c141-4855-aa5c-2f2228573ee5

	/// Other Current Liabilities (AP + Salaries Payable + Taxes Payable) balance as of the selected month-end. Cumulative from inception (no Opening_Balances anchor for this group).
	measure CF_AsOf_OtherCurrentLiabilities = CALCULATE(SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date]<=MAX(Dim_Date[Date])), Dim_Accounts[FSGroup]="Current Liabilities")
		formatString: "€" #,0
		isHidden
		displayFolder: Cash Flow\_Base
		lineageTag: 533f3784-aff6-4d3a-99d5-e21d59424770

	/// Gross Financial (Interest) Expenses only - excludes Financial Income. Used for true interest coverage ratios, where netting against interest income would overstate debt-servicing capacity.
	measure IS_FinancialExpenses = CALCULATE([Actual], Dim_Accounts[FSSubgroup] = "Financial Expenses")
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: 693639c6-6dce-4c5b-9f93-564c00bacf17

	/// Cash & Bank Accounts balance as of selected date. Anchors to most recent OB snapshot <= MaxDate for BOTH 110100 (Cash) and 110200 (Bank Accounts).
	measure BS_AsOf_Cash =
			VAR MaxDate = MAX(Dim_Date[Date])
			VAR AnchorDate = CALCULATE(MAX(Opening_Balances[OB_Date]), FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] <= MaxDate && Opening_Balances[OB_Account] IN {110100, 110200}))
			VAR OB = IF(ISBLANK(AnchorDate), 0, SUMX(FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] = AnchorDate && Opening_Balances[OB_Account] IN {110100, 110200}), Opening_Balances[OB_Amount]))
			VAR GL_Movement = CALCULATE(SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date] <= MaxDate && (ISBLANK(AnchorDate) || Dim_Date[Date] > AnchorDate)), Dim_Accounts[FSSubgroup] = "Cash & Equivalents")
			RETURN OB + GL_Movement
		formatString: "€" #,0
		isHidden
		displayFolder: Balance Sheet\_Base
		lineageTag: 81f21b7d-17d8-472b-9dd0-525f000e5432

	/// Non-Current Assets balance as of selected date. FIXED: anchors to most recent OB snapshot <= MaxDate.
	measure BS_AsOf_NonCurrentAssets =
			VAR MaxDate = MAX(Dim_Date[Date])
			VAR AnchorDate = CALCULATE(MAX(Opening_Balances[OB_Date]), FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] <= MaxDate && Opening_Balances[OB_Group] = "Non-current Assets"))
			VAR OB = IF(ISBLANK(AnchorDate), 0, SUMX(FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] = AnchorDate && Opening_Balances[OB_Group] = "Non-current Assets"), Opening_Balances[OB_Amount]))
			VAR GL_Movement = CALCULATE(SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date] <= MaxDate && (ISBLANK(AnchorDate) || Dim_Date[Date] > AnchorDate)), Dim_Accounts[FSGroup] = "Non-current Assets")
			RETURN OB + GL_Movement
		formatString: "€" #,0
		isHidden
		displayFolder: Balance Sheet\_Base
		lineageTag: ae2b8f96-61fc-4a4b-ae0c-bd8697fb3b3b

	/// Long-term Liabilities balance as of selected date. FIXED: anchors to most recent OB snapshot <= MaxDate.
	measure BS_AsOf_LongTermLiabilities =
			VAR MaxDate = MAX(Dim_Date[Date])
			VAR AnchorDate = CALCULATE(MAX(Opening_Balances[OB_Date]), FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] <= MaxDate && Opening_Balances[OB_Group] = "Long-term Liabilities"))
			VAR OB = IF(ISBLANK(AnchorDate), 0, SUMX(FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] = AnchorDate && Opening_Balances[OB_Group] = "Long-term Liabilities"), Opening_Balances[OB_Amount]))
			VAR GL_Movement = CALCULATE(SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date] <= MaxDate && (ISBLANK(AnchorDate) || Dim_Date[Date] > AnchorDate)), Dim_Accounts[FSGroup] = "Long-term Liabilities")
			RETURN OB + GL_Movement
		formatString: "€" #,0
		isHidden
		displayFolder: Balance Sheet\_Base
		lineageTag: 0ab72870-75ae-4534-abd5-593c285d66cd

	/// Cumulative CapEx spend from inception through selected date - shown as a positive gross investment figure. ABS()-wrapped: CF_InvestingCF is intentionally negative-signed (cash outflow) for the Cash Flow statement; this page needs the positive spend magnitude instead.
	measure CAPEX_Cumulative = ABS(CALCULATE([CF_InvestingCF], FILTER(ALL(Dim_Date), Dim_Date[Date] <= MAX(Dim_Date[Date]))))
		formatString: "€" #,0
		displayFolder: CAPEX
		lineageTag: 569134cb-6cec-4f2e-b5ac-2f05bb19615d

	/// Cumulative Depreciation & Amortisation from inception through selected date. Wraps existing IS_DA.
	measure CAPEX_CumulativeDA = CALCULATE([IS_DA], FILTER(ALL(Dim_Date), Dim_Date[Date] <= MAX(Dim_Date[Date])))
		formatString: "€" #,0
		displayFolder: CAPEX
		lineageTag: 8184cf35-ecfc-4b6a-9ef9-dbad6ac4b856

	/// Cumulative Revenue from inception through selected date. Used as denominator for CapEx capital-intensity ratio.
	measure CAPEX_CumulativeRevenue = CALCULATE([Revenue], FILTER(ALL(Dim_Date), Dim_Date[Date] <= MAX(Dim_Date[Date])))
		formatString: "€" #,0
		displayFolder: CAPEX
		lineageTag: e18b099d-56d5-487e-ab0f-8786a8863bd8

	/// CapEx-to-Depreciation ratio. >1x = asset base growing (investing faster than assets depreciate). <1x = asset base shrinking (harvesting/underinvesting).
	measure CAPEX_ToDepreciationRatio = DIVIDE([CAPEX_Cumulative], [CAPEX_CumulativeDA], BLANK())
		formatString: 0.00"x"
		displayFolder: CAPEX
		lineageTag: 3774f026-d4f7-4164-b05e-586ae1dba04a

	/// CapEx as % of cumulative Revenue. Capital intensity indicator.
	measure CAPEX_PctOfRevenue = DIVIDE([CAPEX_Cumulative], [CAPEX_CumulativeRevenue], BLANK())
		formatString: 0.0%
		displayFolder: CAPEX
		lineageTag: b6c19528-102c-4633-82b0-fe13c2a9c5e7

	/// Cumulative CapEx spend on Machinery & Equipment (140100) since inception. ABS()-wrapped for positive display, same convention as CAPEX_Cumulative.
	measure CAPEX_Cumulative_Machinery = ABS(CALCULATE(-1 * SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date] <= MAX(Dim_Date[Date])), Dim_Accounts[Account] = "140100"))
		formatString: "€" #,0
		displayFolder: CAPEX
		lineageTag: 740ee339-f619-416a-a6b7-8e925d7406cc

	/// Cumulative CapEx spend on Buildings (140200) since inception. ABS()-wrapped for positive display, same convention as CAPEX_Cumulative.
	measure CAPEX_Cumulative_Buildings = ABS(CALCULATE(-1 * SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date] <= MAX(Dim_Date[Date])), Dim_Accounts[Account] = "140200"))
		formatString: "€" #,0
		displayFolder: CAPEX
		lineageTag: 0b7c4829-0cdf-4297-b52d-a8e27024f7d0

	/// FORECAST ASSUMPTION - single source of truth for the annual growth rate applied to out-year projections (2027+). Adjust this one value to update all forward-year forecasts. Confirmed with user: 5%.
	measure Forecast_GrowthRate = 0.05
		formatString: 0.0%
		displayFolder: Forecast
		lineageTag: ec96d031-c769-4562-a36e-befc6fdf4889

	/// MATH FIX: correct subtraction waterfall - each Actual-YTD/Budget-remainder slice ABS'd individually before combining (Financial Income has opposite native sign conventions between Actual and Budget, so must be normalized before summing).
	measure Base_FY_Blended =
			VAR SelYear=SELECTEDVALUE(Dim_Date[Year],0) VAR LastMonth=[IS_LastMonth]
			VAR fs=SELECTEDVALUE(INCOME_Structure[FSGroup],"") VAR sub=SELECTEDVALUE(INCOME_Structure[FSSubgroup],"") VAR rl=SELECTEDVALUE(INCOME_Structure[RowLevel],"")
			
			VAR GroupActualYTD = CALCULATETABLE(ADDCOLUMNS(VALUES(Dim_Accounts[FSGroup]), "@Amt", [Actual]), ALL(Dim_Date), Dim_Date[Year]=SelYear, Dim_Date[Month Number]<=LastMonth)
			VAR GroupBudgetRest = CALCULATETABLE(ADDCOLUMNS(VALUES(Dim_Accounts[FSGroup]), "@Amt", [Budget]), ALL(Dim_Date), Dim_Date[Year]=SelYear, Dim_Date[Month Number]>LastMonth)
			
			VAR vR=SUMX(FILTER(GroupActualYTD,[FSGroup]="Revenue"),[@Amt])+SUMX(FILTER(GroupBudgetRest,[FSGroup]="Revenue"),[@Amt])
			VAR vDedRaw=SUMX(FILTER(GroupActualYTD,[FSGroup]="Deductions"),[@Amt])+SUMX(FILTER(GroupBudgetRest,[FSGroup]="Deductions"),[@Amt])
			VAR vDed=IF(ISBLANK(vDedRaw),0,ABS(vDedRaw))
			VAR vC=SUMX(FILTER(GroupActualYTD,[FSGroup]="COGS"),[@Amt])+SUMX(FILTER(GroupBudgetRest,[FSGroup]="COGS"),[@Amt])
			VAR vO=SUMX(FILTER(GroupActualYTD,[FSGroup]="Operating Expenses"),[@Amt])+SUMX(FILTER(GroupBudgetRest,[FSGroup]="Operating Expenses"),[@Amt])
			VAR vD=SUMX(FILTER(GroupActualYTD,[FSGroup]="D&A"),[@Amt])+SUMX(FILTER(GroupBudgetRest,[FSGroup]="D&A"),[@Amt])
			VAR vFinIncome=ABS(CALCULATE([Actual], ALL(Dim_Date), Dim_Date[Year]=SelYear, Dim_Date[Month Number]<=LastMonth, Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Income"))+ABS(CALCULATE([Budget], ALL(Dim_Date), Dim_Date[Year]=SelYear, Dim_Date[Month Number]>LastMonth, Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Income"))
			VAR vFinExpense=ABS(CALCULATE([Actual], ALL(Dim_Date), Dim_Date[Year]=SelYear, Dim_Date[Month Number]<=LastMonth, Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Expenses"))+ABS(CALCULATE([Budget], ALL(Dim_Date), Dim_Date[Year]=SelYear, Dim_Date[Month Number]>LastMonth, Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Expenses"))
			VAR vF=vFinIncome-vFinExpense
			VAR vT=SUMX(FILTER(GroupActualYTD,[FSGroup]="Taxes"),[@Amt])+SUMX(FILTER(GroupBudgetRest,[FSGroup]="Taxes"),[@Amt])
			
			VAR DetailAmt = CALCULATE([Actual], ALL(Dim_Date), Dim_Date[Year]=SelYear, Dim_Date[Month Number]<=LastMonth, Dim_Accounts[FSGroup]=fs, Dim_Accounts[FSSubgroup]=sub) + CALCULATE([Budget], ALL(Dim_Date), Dim_Date[Year]=SelYear, Dim_Date[Month Number]>LastMonth, Dim_Accounts[FSGroup]=fs, Dim_Accounts[FSSubgroup]=sub)
			
			VAR raw = SWITCH(TRUE(),
			    rl="Header",0,
			    fs="Revenue"&&rl="Detail",vR,
			    fs="Deductions",vDed,
			    fs="Net Revenue",vR-vDed,
			    fs="COGS"&&rl="Detail",DetailAmt,
			    fs="COGS Total",vC,
			    fs="Gross Profit",vR-vDed-vC,
			    fs="Operating Expenses"&&rl="Detail",DetailAmt,
			    fs="OPEX Total",vO,
			    fs="EBITDA",vR-vDed-vC-vO,
			    fs="D&A"&&rl="Detail",vD,
			    fs="EBIT",vR-vDed-vC-vO-vD,
			    fs="Financial Result"&&rl="Detail",DetailAmt,
			    fs="EBT",vR-vDed-vC-vO-vD+vF,
			    fs="Taxes"&&rl="Detail",vT,
			    fs="Net Income",vR-vDed-vC-vO-vD+vF-vT,
			    BLANK())
			RETURN IF(fs IN {"COGS","Operating Expenses","D&A","Taxes","Financial Result"} && rl="Detail", ABS(raw), raw)
		isHidden
		displayFolder: Forecast\_Base
		lineageTag: 8998e6bd-2f72-471c-b738-b132e05a8251

	/// Dynamically detects the last year with actual GL data. Rebuilt with explicit FILTER instead of the bare-table CALCULATE modifier, which wasn't correctly overriding outer date filters.
	measure Forecast_BaseYear = CALCULATE(MAX(Dim_Date[Year]), FILTER(ALL(Dim_Date), CALCULATE(COUNTROWS(GL_Actual)) > 0))
		formatString: 0
		displayFolder: Forecast
		lineageTag: 26ec00f4-94a5-4c32-b027-6ba67a58d1c1

	/// Forward-year forecast (years after the base year) via compound growth off the base year's blended FY figure. INCOME_Structure-aware - works for any P&L line. Reuses Base_FY_Blended entirely, no duplicated P&L logic.
	measure IS_ForwardForecast =
			VAR SelYear=SELECTEDVALUE(Dim_Date[Year],0)
			VAR BaseYear=[Forecast_BaseYear]
			VAR YearsForward=SelYear-BaseYear
			VAR BaseValue=CALCULATE([Base_FY_Blended], ALL(Dim_Date), Dim_Date[Year]=BaseYear)
			VAR GrowthRate=[Forecast_GrowthRate]
			RETURN IF(YearsForward>0, BaseValue*(1+GrowthRate)^YearsForward, BLANK())
		displayFolder: Forecast
		lineageTag: ec2a1438-2176-469e-b795-c6e39dc3db71

	/// Unified forecast measure spanning the full timeline: pure FY Actual for historical years, blended YTD+Budget for the base year, compound-growth projection for years after. One measure for a matrix/chart with Year as a column/axis across 2023-2029.
	measure IS_Forecast_Unified =
			VAR SelYear=SELECTEDVALUE(Dim_Date[Year],0)
			VAR BaseYear=[Forecast_BaseYear]
			RETURN
			SWITCH(
			    TRUE(),
			    SelYear<BaseYear, [FY Actual],
			    SelYear=BaseYear, [Base_FY_Blended],
			    SelYear>BaseYear, [IS_ForwardForecast],
			    BLANK()
			)
		displayFolder: Forecast
		lineageTag: 0a264c6d-02b6-4303-b3d8-4ef40110e4c4

	/// CAGR from base year to 2029. Since growth is a flat compounding assumption, this will always equal Forecast_GrowthRate exactly - included as an explicit, labeled KPI rather than making the viewer infer it from the bars.
	measure Forecast_CAGR = [Forecast_GrowthRate]
		formatString: 0.0%
		displayFolder: Forecast
		lineageTag: 6eb1aed0-876d-45d6-abcf-2a9d70850f39

	/// EBITDA Margin % using the unified forecast (Actual for historical years, blended for base year, projected for out-years). Reuses IS_Forecast_Unified at the appropriate INCOME_Structure context - no duplicated P&L logic.
	measure Forecast_EBITDAMargin =
			VAR Revenue = CALCULATE([IS_Forecast_Unified], INCOME_Structure[FSGroup]="Revenue", INCOME_Structure[RowLevel]="Detail")
			VAR EBITDA = CALCULATE([IS_Forecast_Unified], INCOME_Structure[FSGroup]="EBITDA")
			RETURN DIVIDE(EBITDA, Revenue, BLANK())
		formatString: 0.0%
		displayFolder: Forecast
		lineageTag: 0d85f026-8ee5-4d44-a79b-cdd23d3e0fd0

	/// Net Income Margin % using the unified forecast. Reuses IS_Forecast_Unified.
	measure Forecast_NetMargin =
			VAR Revenue = CALCULATE([IS_Forecast_Unified], INCOME_Structure[FSGroup]="Revenue", INCOME_Structure[RowLevel]="Detail")
			VAR NetIncome = CALCULATE([IS_Forecast_Unified], INCOME_Structure[FSGroup]="Net Income")
			RETURN DIVIDE(NetIncome, Revenue, BLANK())
		formatString: 0.0%
		displayFolder: Forecast
		lineageTag: af131090-75a5-4d72-b49b-70cb1c299e4e

	/// Gross Margin % using the unified forecast. Reuses IS_Forecast_Unified.
	measure Forecast_GrossMargin =
			VAR Revenue = CALCULATE([IS_Forecast_Unified], INCOME_Structure[FSGroup]="Revenue", INCOME_Structure[RowLevel]="Detail")
			VAR GrossProfit = CALCULATE([IS_Forecast_Unified], INCOME_Structure[FSGroup]="Gross Profit")
			RETURN DIVIDE(GrossProfit, Revenue, BLANK())
		formatString: 0.0%
		displayFolder: Forecast
		lineageTag: d3ca2168-35a7-44d4-ba6f-0d348e7f4f00

	/// Forecast 2023 - fixed year, Table column. Mirrors BS_2023's convention.
	measure 2023 = CALCULATE([IS_Forecast_Unified], ALL(Dim_Date), Dim_Date[Year]=2023)
		formatString: #,0;-#,0;""
		displayFolder: Forecast\Statement Columns
		lineageTag: 20c229e7-f391-48f0-be22-d846252b7a99

	/// Forecast 2024 - fixed year, Table column.
	measure 2024 = CALCULATE([IS_Forecast_Unified], ALL(Dim_Date), Dim_Date[Year]=2024)
		formatString: #,0;-#,0;""
		displayFolder: Forecast\Statement Columns
		lineageTag: d6766157-c332-4c5b-8329-cf9ee8e76cbf

	/// Forecast 2025 - fixed year, Table column.
	measure 2025 = CALCULATE([IS_Forecast_Unified], ALL(Dim_Date), Dim_Date[Year]=2025)
		formatString: #,0;-#,0;""
		displayFolder: Forecast\Statement Columns
		lineageTag: 9a3477b8-ca87-45a2-b9ca-b867689fa6f0

	/// Forecast 2026 - base year, blended YTD Actual + Budget. Fixed year, Table column.
	measure 2026 = CALCULATE([IS_Forecast_Unified], ALL(Dim_Date), Dim_Date[Year]=2026)
		formatString: #,0;-#,0;""
		displayFolder: Forecast\Statement Columns
		lineageTag: c7c6706e-a6e7-4938-b005-2ee46887eede

	/// Forecast 2027 - projected, +5% compound. Fixed year, Table column.
	measure 2027 = CALCULATE([IS_Forecast_Unified], ALL(Dim_Date), Dim_Date[Year]=2027)
		formatString: #,0;-#,0;""
		displayFolder: Forecast\Statement Columns
		lineageTag: cd103ca2-3f39-4b83-bfd5-cb19a7d42844

	/// Forecast 2028 - projected, +5% compound. Fixed year, Table column.
	measure 2028 = CALCULATE([IS_Forecast_Unified], ALL(Dim_Date), Dim_Date[Year]=2028)
		formatString: #,0;-#,0;""
		displayFolder: Forecast\Statement Columns
		lineageTag: 11a7fac7-7ec0-4b9f-9d4e-72b746860ad6

	/// Forecast 2029 - projected, +5% compound. Fixed year, Table column.
	measure 2029 = CALCULATE([IS_Forecast_Unified], ALL(Dim_Date), Dim_Date[Year]=2029)
		formatString: #,0;-#,0;""
		displayFolder: Forecast\Statement Columns
		lineageTag: 820bbd8b-9ddd-4bad-b389-963aa0b3bb61

	/// Revenue FY26 KPI card - FIXED to the base year, immune to the page's Year slicer. Base year resolved to a VAR first (DAX engine limitation: measure reference directly inline in a CALCULATE boolean filter isn't supported).
	measure Forecast_Revenue =
			VAR BaseYr = [Forecast_BaseYear]
			RETURN
			CALCULATE(
			    [IS_Forecast_Unified],
			    ALL(Dim_Date),
			    Dim_Date[Year] = BaseYr,
			    INCOME_Structure[FSGroup] = "Revenue",
			    INCOME_Structure[RowLevel] = "Detail"
			)
		formatString: "€" #,0
		displayFolder: Forecast\KPI Cards
		lineageTag: 0e0c189c-ec95-4d45-980f-7097b6067a6e

	/// Gross Profit FY26 KPI card - FIXED to the base year, immune to the page's Year slicer.
	measure Forecast_GrossProfit =
			VAR BaseYr = [Forecast_BaseYear]
			RETURN
			CALCULATE(
			    [IS_Forecast_Unified],
			    ALL(Dim_Date),
			    Dim_Date[Year] = BaseYr,
			    INCOME_Structure[FSGroup] = "Gross Profit"
			)
		formatString: "€" #,0
		displayFolder: Forecast\KPI Cards
		lineageTag: 3f40e6b7-37a8-4111-8273-4ff3cbd2c455

	/// EBITDA FY26 KPI card - FIXED to the base year, immune to the page's Year slicer.
	measure Forecast_EBITDA =
			VAR BaseYr = [Forecast_BaseYear]
			RETURN
			CALCULATE(
			    [IS_Forecast_Unified],
			    ALL(Dim_Date),
			    Dim_Date[Year] = BaseYr,
			    INCOME_Structure[FSGroup] = "EBITDA"
			)
		formatString: "€" #,0
		displayFolder: Forecast\KPI Cards
		lineageTag: e7e8f6b7-9ea9-45cb-ae88-b7b8242f81a2

	/// EBIT FY26 KPI card - FIXED to the base year, immune to the page's Year slicer.
	measure Forecast_EBIT =
			VAR BaseYr = [Forecast_BaseYear]
			RETURN
			CALCULATE(
			    [IS_Forecast_Unified],
			    ALL(Dim_Date),
			    Dim_Date[Year] = BaseYr,
			    INCOME_Structure[FSGroup] = "EBIT"
			)
		formatString: "€" #,0
		displayFolder: Forecast\KPI Cards
		lineageTag: 05dbf4b9-be4a-4c38-81dc-30d02d3073b4

	/// Net Income FY26 KPI card - FIXED to the base year, immune to the page's Year slicer.
	measure Forecast_NetIncome =
			VAR BaseYr = [Forecast_BaseYear]
			RETURN
			CALCULATE(
			    [IS_Forecast_Unified],
			    ALL(Dim_Date),
			    Dim_Date[Year] = BaseYr,
			    INCOME_Structure[FSGroup] = "Net Income"
			)
		formatString: "€" #,0
		displayFolder: Forecast\KPI Cards
		lineageTag: c9e8d804-1b96-42ab-ad8b-5f99cde72829

	/// Revenue series for the multi-line trend chart. FIXED: was wrapping the now-pinned Forecast_Revenue (base-year-only), making every point on the chart identical. Now calls IS_Forecast_Unified directly, which correctly varies by the chart's own Year axis context.
	measure Forecast_Revenue_Line =
			CALCULATE(
			    [IS_Forecast_Unified],
			    INCOME_Structure[FSGroup] = "Revenue",
			    INCOME_Structure[RowLevel] = "Detail"
			)
		formatString: "€" #,0
		displayFolder: Forecast\Trend Chart
		lineageTag: fe67290b-9878-46d1-8005-4dbdd6d558bc

	/// EBITDA series for the multi-line trend chart. FIXED: same issue - was wrapping the pinned Forecast_EBITDA.
	measure Forecast_EBITDA_Line =
			CALCULATE(
			    [IS_Forecast_Unified],
			    INCOME_Structure[FSGroup] = "EBITDA"
			)
		formatString: "€" #,0
		displayFolder: Forecast\Trend Chart
		lineageTag: f52fa6aa-5a56-4e53-aa76-a53facdae157

	/// Net Income series for the multi-line trend chart. FIXED: same issue - was wrapping the pinned Forecast_NetIncome.
	measure Forecast_NetIncome_Line =
			CALCULATE(
			    [IS_Forecast_Unified],
			    INCOME_Structure[FSGroup] = "Net Income"
			)
		formatString: "€" #,0
		displayFolder: Forecast\Trend Chart
		lineageTag: 7363ef28-af06-4a89-bf6e-46dfb69ac9a3

	/// Revenue KPI card - YTD through last actual month of the base year. FIXED: IS_LastMonth needs Year pinned first before it can resolve - now computed inside its own CALCULATE with BaseYr already active.
	measure KPI_Revenue_YTD =
			VAR BaseYr = [Forecast_BaseYear]
			VAR LastMo = CALCULATE([IS_LastMonth], ALL(Dim_Date), Dim_Date[Year] = BaseYr)
			RETURN
			CALCULATE([Revenue], ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] <= LastMo)
		formatString: "€" #,0
		displayFolder: Income Statement\KPI Cards
		lineageTag: 6a246355-8289-485b-ba57-7b9e0f215ad7

	/// Gross Profit KPI card - YTD through last actual month. Same fix as KPI_Revenue_YTD.
	measure KPI_GrossProfit_YTD =
			VAR BaseYr = [Forecast_BaseYear]
			VAR LastMo = CALCULATE([IS_LastMonth], ALL(Dim_Date), Dim_Date[Year] = BaseYr)
			RETURN
			CALCULATE([Gross Profit], ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] <= LastMo)
		formatString: "€" #,0
		displayFolder: Income Statement\KPI Cards
		lineageTag: 53ddf389-09e1-4e21-90da-6ca64c8902fb

	/// EBITDA KPI card - YTD through last actual month. Same fix.
	measure KPI_EBITDA_YTD =
			VAR BaseYr = [Forecast_BaseYear]
			VAR LastMo = CALCULATE([IS_LastMonth], ALL(Dim_Date), Dim_Date[Year] = BaseYr)
			RETURN
			CALCULATE([EBITDA], ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] <= LastMo)
		formatString: "€" #,0
		displayFolder: Income Statement\KPI Cards
		lineageTag: abeaea24-fc2b-4718-977a-d41ed22e8ff7

	/// EBIT KPI card - YTD through last actual month. Same fix.
	measure KPI_EBIT_YTD =
			VAR BaseYr = [Forecast_BaseYear]
			VAR LastMo = CALCULATE([IS_LastMonth], ALL(Dim_Date), Dim_Date[Year] = BaseYr)
			RETURN
			CALCULATE([EBIT], ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] <= LastMo)
		formatString: "€" #,0
		displayFolder: Income Statement\KPI Cards
		lineageTag: d45f0b01-ac56-485a-8e93-8060b0c0868c

	/// Net Income KPI card - YTD through last actual month. Same fix.
	measure KPI_NetIncome_YTD =
			VAR BaseYr = [Forecast_BaseYear]
			VAR LastMo = CALCULATE([IS_LastMonth], ALL(Dim_Date), Dim_Date[Year] = BaseYr)
			RETURN
			CALCULATE([Net Income], ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] <= LastMo)
		formatString: "€" #,0
		displayFolder: Income Statement\KPI Cards
		lineageTag: 68a0ea1c-0dd8-470e-847c-6c8a2299ebf1

	/// Revenue Budget KPI card - full year budget for the base year (pacing target for YTD actual comparison). Pinned.
	measure KPI_RevenueBudget_FY =
			VAR BaseYr = [Forecast_BaseYear]
			RETURN
			CALCULATE([IS_RevenueBudget], ALL(Dim_Date), Dim_Date[Year] = BaseYr)
		formatString: "€" #,0
		displayFolder: Income Statement\KPI Cards
		lineageTag: 6220ca80-712c-4101-8ac4-fe4f94c30c3d

	/// Revenue for the single last actual month (not YTD). Used for month-over-month commentary.
	measure KPI_Revenue_LastMonth =
			VAR BaseYr = [Forecast_BaseYear]
			VAR LastMo = CALCULATE([IS_LastMonth], ALL(Dim_Date), Dim_Date[Year] = BaseYr)
			RETURN
			CALCULATE([Revenue], ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] = LastMo)
		formatString: "€" #,0
		displayFolder: Income Statement\KPI Cards
		lineageTag: ed417b34-8e3d-483f-9871-f7866ca74313

	/// Net Income for the single last actual month (not YTD).
	measure KPI_NetIncome_LastMonth =
			VAR BaseYr = [Forecast_BaseYear]
			VAR LastMo = CALCULATE([IS_LastMonth], ALL(Dim_Date), Dim_Date[Year] = BaseYr)
			RETURN
			CALCULATE([Net Income], ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] = LastMo)
		formatString: "€" #,0
		displayFolder: Income Statement\KPI Cards
		lineageTag: 3212c12a-2fc8-4be4-997c-14c46f5166c8

	/// All FORMAT() calls now pass explicit it-IT locale (period thousands separator, comma decimal separator), matching the same fix applied to CF_Commentary.
	measure Nav_ExecutiveTicker =
			VAR BaseYr = [Forecast_BaseYear]
			VAR LastMo = CALCULATE([IS_LastMonth], ALL(Dim_Date), Dim_Date[Year] = BaseYr)
			VAR MonthName = CALCULATE(MAX(Dim_Date[Month]), ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] = LastMo)
			
			VAR RevYTD = [KPI_Revenue_YTD]
			VAR GPYTD = [KPI_GrossProfit_YTD]
			VAR EBITDAYTD = [KPI_EBITDA_YTD]
			VAR NIYTD = [KPI_NetIncome_YTD]
			
			VAR BudgetYTD = CALCULATE([IS_RevenueBudget], ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] <= LastMo)
			VAR VarPct = DIVIDE(RevYTD - BudgetYTD, ABS(BudgetYTD), 0)
			VAR VarLabel = IF(VarPct >= 0, "ahead of", "behind")
			
			VAR RevPY = CALCULATE([Revenue], ALL(Dim_Date), Dim_Date[Year] = BaseYr - 1, Dim_Date[Month Number] <= LastMo)
			VAR RevPYPct = DIVIDE(RevYTD - RevPY, ABS(RevPY), BLANK())
			VAR PYLabel = IF(RevPYPct >= 0, "up", "down")
			
			VAR EBITDAMarginYTD = DIVIDE(EBITDAYTD, RevYTD, BLANK())
			VAR NIMarginYTD = DIVIDE(NIYTD, RevYTD, BLANK())
			
			VAR ClosingCash = CALCULATE([CF_ClosingCash], ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] = LastMo)
			VAR MinTarget = CALCULATE([CF_MinCashTarget], ALL(Dim_Date), Dim_Date[Year] = BaseYr, Dim_Date[Month Number] = LastMo)
			VAR CashGap = ClosingCash - MinTarget
			VAR CashLabel = IF(CashGap >= 0, "above", "below")
			
			RETURN
			MonthName & " " & BaseYr & " YTD:   Revenue " & FORMAT(RevYTD,"€ #,##0,,.0","it-IT") & "M (" & FORMAT(ABS(RevPYPct),"0.0%","it-IT") & " " & PYLabel & " YoY, " & FORMAT(ABS(VarPct),"0.0%","it-IT") & " " & VarLabel & " budget)" &
			"     |     Gross Profit " & FORMAT(GPYTD,"€ #,##0,,.0","it-IT") & "M" &
			"     |     EBITDA " & FORMAT(EBITDAYTD,"€ #,##0,,.0","it-IT") & "M (" & FORMAT(EBITDAMarginYTD,"0.0%","it-IT") & " margin)" &
			"     |     Net Income " & FORMAT(NIYTD,"€ #,##0,,.0","it-IT") & "M (" & FORMAT(NIMarginYTD,"0.0%","it-IT") & " margin)" &
			"     |     Cash " & FORMAT(ClosingCash,"€ #,##0,,.0","it-IT") & "M, " & FORMAT(ABS(CashGap),"€ #,##0,,.0","it-IT") & "M " & CashLabel & " minimum target"
		displayFolder: Navigation
		lineageTag: 1f812c75-49de-4b06-92d3-722ff77c4a3c

	/// The true last calendar date with actual GL data ("today" for this model). Dynamic - no hardcoding. Used to truncate trend charts/tables so they stop at real data instead of drawing frozen carry-forward values into unknown future dates.
	measure Forecast_LastActualDate = CALCULATE(MAX(Dim_Date[Date]), FILTER(ALL(Dim_Date), CALCULATE(COUNTROWS(GL_Actual)) > 0))
		formatString: dd/mm/yyyy
		displayFolder: Forecast
		lineageTag: 9fffc492-0a25-48e5-bd0b-0e2ddf5a5954

	/// Dynamic 'Data as of' label for the Navigation page header. Reuses Forecast_LastActualDate - no hardcoding, self-updates as real data grows.
	measure Nav_DataAsOf = FORMAT([Forecast_LastActualDate], "MMMM YYYY")
		displayFolder: Navigation
		lineageTag: df89f83a-d4ad-41c7-872b-00dcc666edb4

	/// Month name corresponding to the last actual GL date ("today"). Fixed: VAR renamed to avoid colliding with DAX's built-in LASTDATE() function.
	measure IS_DefaultMonthName =
			VAR LatestActualDt = [Forecast_LastActualDate]
			RETURN CALCULATE(SELECTEDVALUE(Dim_Date[Month]), ALL(Dim_Date), Dim_Date[Date] = LatestActualDt)
		displayFolder: Income Statement\Selected Month
		lineageTag: 7b2c8860-f248-408b-b12c-d1ec032eca65

	/// Actual for whatever month is selected in the slicer (defaults to last actual month if none selected). Reuses the 12 existing month measures - no duplicated logic. Core of the column-count reduction fix: replaces 12 simultaneous Actual columns with 1.
	measure IS_SelMonth_Actual =
			VAR SelMonth = SELECTEDVALUE(Dim_Date[Month], [IS_DefaultMonthName])
			RETURN
			SWITCH(
			    SelMonth,
			    "Jan", [Jan Actual], "Feb", [Feb Actual], "Mar", [Mar Actual], "Apr", [Apr Actual],
			    "May", [May Actual], "Jun", [Jun Actual], "Jul", [Jul Actual], "Aug", [Aug Actual],
			    "Sep", [Sep Actual], "Oct", [Oct Actual], "Nov", [Nov Actual], "Dec", [Dec Actual],
			    BLANK()
			)
		displayFolder: Income Statement\Selected Month
		lineageTag: 6dd0b548-1706-48dd-ac05-6532aaed706b

	/// Budget for whatever month is selected. Reuses the 12 existing month measures.
	measure IS_SelMonth_Budget =
			VAR SelMonth = SELECTEDVALUE(Dim_Date[Month], [IS_DefaultMonthName])
			RETURN
			SWITCH(
			    SelMonth,
			    "Jan", [Jan Budget], "Feb", [Feb Budget], "Mar", [Mar Budget], "Apr", [Apr Budget],
			    "May", [May Budget], "Jun", [Jun Budget], "Jul", [Jul Budget], "Aug", [Aug Budget],
			    "Sep", [Sep Budget], "Oct", [Oct Budget], "Nov", [Nov Budget], "Dec", [Dec Budget],
			    BLANK()
			)
		displayFolder: Income Statement\Selected Month
		lineageTag: a14d889e-88f1-491d-932b-dc8f0c39d59e

	/// Variance for whatever month is selected. Reuses the 12 existing month measures.
	measure IS_SelMonth_Var =
			VAR SelMonth = SELECTEDVALUE(Dim_Date[Month], [IS_DefaultMonthName])
			RETURN
			SWITCH(
			    SelMonth,
			    "Jan", [Jan Var], "Feb", [Feb Var], "Mar", [Mar Var], "Apr", [Apr Var],
			    "May", [May Var], "Jun", [Jun Var], "Jul", [Jul Var], "Aug", [Aug Var],
			    "Sep", [Sep Var], "Oct", [Oct Var], "Nov", [Nov Var], "Dec", [Dec Var],
			    BLANK()
			)
		displayFolder: Income Statement\Selected Month
		lineageTag: 9af57be6-068b-417f-8838-8343db1bddb9

	/// Variance % for whatever month is selected. Reuses the 12 existing month measures.
	measure IS_SelMonth_VarPct =
			VAR SelMonth = SELECTEDVALUE(Dim_Date[Month], [IS_DefaultMonthName])
			RETURN
			SWITCH(
			    SelMonth,
			    "Jan", [Jan Var%], "Feb", [Feb Var%], "Mar", [Mar Var%], "Apr", [Apr Var%],
			    "May", [May Var%], "Jun", [Jun Var%], "Jul", [Jul Var%], "Aug", [Aug Var%],
			    "Sep", [Sep Var%], "Oct", [Oct Var%], "Nov", [Nov Var%], "Dec", [Dec Var%],
			    BLANK()
			)
		displayFolder: Income Statement\Selected Month
		lineageTag: 309b2f43-bb70-41d4-bd26-152867f953ac

	column Column
		formatString: 0
		lineageTag: cd43175d-8549-43da-8f51-6049df19fb52
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Column]

		annotation SummarizationSetBy = Automatic

	partition M_Measures = calculated
		mode: import
		source = Row("Column", BLANK())

	annotation PBI_Id = 4cf8cb14c0844070891f84b085ba57c4

	annotation 436ba87b-9c83-4389-a31b-ebd06a36be98 = {"Expression":""}

