	/// Returns 1 if the selected year has any actual data, used as visual filter to hide empty months
	measure IS_HasData =
			VAR yr = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			RETURN
			IF(
			    CALCULATE(COUNTROWS(GL_Actual), ALL(Dim_Date), Dim_Date[Year] = yr) > 0,
			    1, 0
			)
		formatString: 0
		displayFolder: Income Statement\Monthly Columns
		lineageTag: df17b82a-97a4-4c03-a724-d95985859b85

	/// Last month with actual data for selected year
	measure IS_LastMonth =
			VAR yr = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			RETURN
			CALCULATE(
			    MAX(Dim_Date[Month Number]),
			    GL_Actual,
			    ALL(Dim_Date),
			    Dim_Date[Year] = yr
			)
		formatString: 0
		displayFolder: Income Statement\Monthly Columns
		lineageTag: 5a5865be-9254-4850-8cc5-cee9ae0347eb

	/// Font color for IS table rows
	measure IS_FontColor =
			VAR rowLevel = SELECTEDVALUE(INCOME_Structure[RowLevel], "")
			RETURN
			SWITCH(
			    TRUE(),
			    rowLevel = "Header",     "#FFFFFF",
			    rowLevel = "GrandTotal", "#FFFFFF",
			    rowLevel = "Total",      "#FFFFFF",
			    rowLevel = "Subtotal",   "#FFFFFF",
			    rowLevel = "Detail",     "#FFFFFF",
			    "#FFFFFF"
			)
		displayFolder: Income Statement\Formatting
		lineageTag: 7812b9fb-5e43-4862-ac04-ce29b7093ca8

	/// MATH FIX: Revenue Deductions and Financial Income carry native-negative raw signs (contra-revenue/credit convention) that made subtotal subtraction silently behave like addition. Now converts each group to its true magnitude (ABS) before combining, so Net Revenue = Revenue - Deductions, Gross Profit = Net Revenue - COGS, EBITDA = Gross Profit - OPEX, EBIT = EBITDA - D&A, EBT = EBIT + net Financial Result, Net Income = EBT - Taxes, all via correct subtraction.
	measure Base_Jan_A =
			VAR hasYearFilter=HASONEVALUE(Dim_Date[Year]) VAR yr=SELECTEDVALUE(Dim_Date[Year],0)
			VAR fs=SELECTEDVALUE(INCOME_Structure[FSGroup],"") VAR sub=SELECTEDVALUE(INCOME_Structure[FSSubgroup],"") VAR rl=SELECTEDVALUE(INCOME_Structure[RowLevel],"")
			
			VAR GroupSums = CALCULATETABLE(ADDCOLUMNS(VALUES(Dim_Accounts[FSGroup]), "@Amt", [Actual]), ALL(Dim_Date), Dim_Date[Month Number]=1, IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()))
			
			VAR vR=SUMX(FILTER(GroupSums,[FSGroup]="Revenue"),[@Amt])
			VAR vDedRaw=SUMX(FILTER(GroupSums,[FSGroup]="Deductions"),[@Amt])
			VAR vDed=IF(ISBLANK(vDedRaw),0,ABS(vDedRaw))
			VAR vC=SUMX(FILTER(GroupSums,[FSGroup]="COGS"),[@Amt])
			VAR vO=SUMX(FILTER(GroupSums,[FSGroup]="Operating Expenses"),[@Amt])
			VAR vD=SUMX(FILTER(GroupSums,[FSGroup]="D&A"),[@Amt])
			VAR vFinIncome=ABS(CALCULATE([Actual], ALL(Dim_Date), Dim_Date[Month Number]=1, IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Income"))
			VAR vFinExpense=ABS(CALCULATE([Actual], ALL(Dim_Date), Dim_Date[Month Number]=1, IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Expenses"))
			VAR vF=vFinIncome-vFinExpense
			VAR vT=SUMX(FILTER(GroupSums,[FSGroup]="Taxes"),[@Amt])
			
			VAR DetailAmt = CALCULATE([Actual], ALL(Dim_Date), Dim_Date[Month Number]=1, IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Accounts[FSGroup]=fs, Dim_Accounts[FSSubgroup]=sub)
			
			VAR raw = SWITCH(TRUE(),
			    rl="Header",0,
			    fs="Revenue"&&rl="Detail",vR,
			    fs="Deductions",vDed,
			    fs="Net Revenue",vR-vDed,
			    fs="COGS"&&rl="Detail",DetailAmt,
			    fs="COGS Total",vC,
			    fs="Gross Profit",vR-vDed-vC,
			    fs="Operating Expenses"&&rl="Detail",DetailAmt,
			    fs="OPEX Total",vO,
			    fs="EBITDA",vR-vDed-vC-vO,
			    fs="D&A"&&rl="Detail",vD,
			    fs="EBIT",vR-vDed-vC-vO-vD,
			    fs="Financial Result"&&rl="Detail",DetailAmt,
			    fs="EBT",vR-vDed-vC-vO-vD+vF,
			    fs="Taxes"&&rl="Detail",vT,
			    fs="Net Income",vR-vDed-vC-vO-vD+vF-vT,
			    BLANK())
			RETURN IF(fs IN {"COGS","Operating Expenses","D&A","Taxes","Financial Result"} && rl="Detail", ABS(raw), raw)
		formatString: 0
		isHidden
		displayFolder: Income Statement\_Base
		lineageTag: 77f11658-5ba6-49fb-ba53-2583814771c1

	/// MATH FIX: correct subtraction waterfall using magnitudes for Deductions and net Financial Result.
	measure Base_Jan_B =
			VAR hasYearFilter=HASONEVALUE(Dim_Date[Year]) VAR yr=SELECTEDVALUE(Dim_Date[Year],0)
			VAR fs=SELECTEDVALUE(INCOME_Structure[FSGroup],"") VAR sub=SELECTEDVALUE(INCOME_Structure[FSSubgroup],"") VAR rl=SELECTEDVALUE(INCOME_Structure[RowLevel],"")
			
			VAR GroupSums = CALCULATETABLE(ADDCOLUMNS(VALUES(Dim_Accounts[FSGroup]), "@Amt", [Budget]), ALL(Dim_Date), Dim_Date[Month Number]=1, IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()))
			
			VAR vR=SUMX(FILTER(GroupSums,[FSGroup]="Revenue"),[@Amt])
			VAR vDedRaw=SUMX(FILTER(GroupSums,[FSGroup]="Deductions"),[@Amt])
			VAR vDed=IF(ISBLANK(vDedRaw),0,ABS(vDedRaw))
			VAR vC=SUMX(FILTER(GroupSums,[FSGroup]="COGS"),[@Amt])
			VAR vO=SUMX(FILTER(GroupSums,[FSGroup]="Operating Expenses"),[@Amt])
			VAR vD=SUMX(FILTER(GroupSums,[FSGroup]="D&A"),[@Amt])
			VAR vFinIncome=ABS(CALCULATE([Budget], ALL(Dim_Date), Dim_Date[Month Number]=1, IF(hasYearFilter, Dim_Date[Year]=yr, TRUE()), Dim_Accounts[FSGroup]="Financial Result", Dim_Accounts[FSSubgroup]="Financial Income"))
