table M_Measures
	lineageTag: 0686b20f-f7b0-4b8f-b330-dd1b0c0c4dbc

	measure 'Actual Amount' =
			
			SUM(GL_Actual[Amount])
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: 68878804-36d7-4f21-b79c-b016615d5d62

	measure 'Budget Amount' =
			
			SUM(GL_Budget[BudgetAmount])
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: d80f1dd4-c238-41ef-9c94-afe1962d625f

	measure Variance0 =
			
			[Actual Amount] - [Budget Amount]
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: bfaa34f0-4928-479e-950e-de5ece91b0c7

	measure 'Variance0 %' =
			
			DIVIDE([Variance0], [Budget Amount],0)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 93c32a84-103f-48c6-b010-189d85593caa

	/// Actual value - Deductions sign = 1 (source already negative). Rewritten as a single vectorized SUMX over the fact table (sign precomputed on Dim_Accounts) instead of SUMX-over-dimension with per-account context transition - eliminates the per-account storage-engine round trips that made the Income Statement/Forecast matrices exceed Power BI Service's per-visual memory limit.
	measure Actual = SUMX(GL_Actual, GL_Actual[Amount] * RELATED(Dim_Accounts[ActualSign]))
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: 02786b97-1034-4870-82c9-f05baf8ea1da

	/// Budget value - Deductions sign = -1 (source is positive magnitude). Rewritten as a single vectorized SUMX over the fact table (sign precomputed on Dim_Accounts) - see Actual for rationale.
	measure Budget = SUMX(GL_Budget, GL_Budget[BudgetAmount] * RELATED(Dim_Accounts[BudgetSign]))
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: 3536a6ac-9467-49f0-a1c6-36b424202ccd

	measure VAR =
			
			[Actual] - [Budget]
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: 980a6732-da0e-47b2-a04b-ba872ea8d14b

	measure 'VAR %' =
			
			DIVIDE([VAR],[Budget],0)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: d47441c3-a4da-4d0e-bf25-0b56013e4abf

	measure Revenue =
			
			CALCULATE(
			    [Actual],
			    Dim_Accounts[FSGroup] = "Revenue"
			)
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: c5edb24c-f587-4b21-9a53-d3dbe6baf929

	/// MATH FIX: was skipping Revenue Deductions entirely (Gross Profit = Revenue - COGS). Now correctly computes Net Revenue = Revenue - Deductions first, matching the Income Statement matrix logic: Gross Profit = Net Revenue - COGS.
	measure 'Gross Profit' =
			VAR Ded = CALCULATE([Actual], Dim_Accounts[FSGroup] = "Deductions")
			VAR DedAbs = IF(ISBLANK(Ded), 0, ABS(Ded))
			RETURN
			[Revenue] - DedAbs - CALCULATE([Actual], Dim_Accounts[FSGroup] = "COGS")
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: d77fa0d8-6e8d-4458-822f-2bbcd6da876f

	/// MATH FIX: reuses the now-corrected [Gross Profit] (which properly subtracts Deductions) instead of re-deriving Revenue-COGS-OPEX independently.
	measure EBITDA = [Gross Profit] - CALCULATE([Actual], Dim_Accounts[FSGroup] = "Operating Expenses")
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: 62a41958-b8e7-4d68-8053-5fd342289d9d

	measure EBIT =
			
			[EBITDA]
			- CALCULATE([Actual], Dim_Accounts[FSGroup] = "D&A")
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: 01df7a5e-2f2b-4ff0-834f-e0bf96689670

	/// MATH FIX: Financial Income/Expense carry native-negative raw signs (same root cause as the matrix bug), so the old raw signed FSGroup-level sum silently went the wrong direction. Now nets true magnitudes (Income - Expense) before adding to EBIT, matching the Income Statement matrix.
	measure 'Net Income' =
			VAR FinIncome = ABS(CALCULATE([Actual], Dim_Accounts[FSGroup] = "Financial Result", Dim_Accounts[FSSubgroup] = "Financial Income"))
			VAR FinExpense = ABS(CALCULATE([Actual], Dim_Accounts[FSGroup] = "Financial Result", Dim_Accounts[FSSubgroup] = "Financial Expenses"))
			VAR NetFin = FinIncome - FinExpense
			RETURN
			[EBIT] + NetFin - CALCULATE([Actual], Dim_Accounts[FSGroup] = "Taxes")
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: 2eaf60d7-700a-4908-8e42-196bb679ab33

	measure 'FS Report Value' =
			
			VAR CurrentFS =
			    SELECTEDVALUE(INCOME_Structure[FSGroup])
			
			VAR CurrentSub =
			    SELECTEDVALUE(INCOME_Structure[FSSubgroup])
			
			RETURN
			
			SWITCH(
			    TRUE(),
			
			    CurrentFS = "Gross Profit",
			        [Gross Profit],
			
			    CurrentFS = "EBITDA",
			        [EBITDA],
			
			    CurrentFS = "EBIT",
			        [EBIT],
			
			    CurrentFS = "Net Income",
			        [Net Income],
			
			    CALCULATE(
			        [Actual],
			
			        TREATAS(
			            {CurrentFS},
			            Dim_Accounts[FSGroup]
			        ),
			
			        TREATAS(
			            {CurrentSub},
			            Dim_Accounts[FSSubgroup]
			        )
			    )
			)
		formatString: "€"\ #,0;-"€"\ #,0;"€"\ #,0
		lineageTag: b72e2e7f-f3e9-41d3-96bb-563dcbed40cc

	/// Total Assets = Current + Non-Current. Composed from the same validated building blocks used elsewhere - guarantees internal consistency.
	measure BS_TotalAssets = [BS_CurrentAssets] + [BS_NonCurrentAssets]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: ebedb798-d0dc-4b99-ae4f-db9d932931bf

	/// Current Assets = Cash + AR + Inventory + Prepaid, each at true GL sign. CHANGED 2026-07-07: removed per-component ABS() that was masking a genuine negative-Inventory data anomaly as a phantom positive asset. See Management Report data quality note.
	measure BS_CurrentAssets =
			-- Components kept at their true GL-derived sign (no per-component ABS()).
			-- Cash, AR, and Prepaid are debit-normal and always non-negative in this GL,
			-- so this is a no-op for them. Inventory is intentionally NOT force-positive:
			-- a negative Inventory balance is a real GL/data anomaly (see Opening_Balances
			-- vs GL_Actual reconciliation note), and masking it with ABS() would convert a
			-- data error into a phantom asset instead of surfacing it.
			[BS_AsOf_Cash] + [CF_AsOf_AccountsReceivable] + [CF_AsOf_Inventory] + [CF_AsOf_PrepaidExpenses]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: 714867f8-968c-4d71-88d5-cde518d3c8e7

	/// Non-Current Assets - now correctly month-aware.
	measure BS_NonCurrentAssets = [BS_AsOf_NonCurrentAssets]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: cb46384d-cbb3-43cb-aef0-a32e65e63605

	/// Cash - now correctly month-aware via BS_AsOf_Cash.
	measure BS_Cash = [BS_AsOf_Cash]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: 7a94e03e-444d-483e-be48-6b8f57b03a48

	/// MATH FIX: was a naive lifetime cumulative SUM(GL_Actual[Amount]) with no opening-balance anchor, inflating to €231M. Now reuses the already-correct, OB-anchored CF_AsOf_AccountsReceivable (same approach validated in BS_2025/BS_2026).
	measure BS_AccountsReceivable = ABS([CF_AsOf_AccountsReceivable])
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: 0584eab2-80ff-49ea-a127-f0334274cfa0

	/// MATH FIX: was a naive lifetime cumulative SUM(GL_Actual[Amount]) with no opening-balance anchor, inflating to €132.7M. Now reuses the already-correct, OB-anchored CF_AsOf_Inventory (same approach validated in BS_2025/BS_2026).
	measure BS_Inventory = ABS([CF_AsOf_Inventory])
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: 5a7053cd-0b35-4e6d-b5fd-41a6dd2b70ed

	/// Total Liabilities = Current + Long-term. Composed from the same components as their individual measures - previously computed independently via a different GL filter, which caused the balance-check failure.
	measure BS_TotalLiabilities = [BS_CurrentLiabilities] + [BS_LongTermLiabilities]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: c4d67162-97a9-475c-ace8-ae4a051a9e07

	/// Current Liabilities = AP + Salaries Payable + Taxes Payable. ABS()-wrapped for correct Balance Sheet presentation (Liabilities always positive) - CF_AsOf_OtherCurrentLiabilities preserves raw sign for Cash Flow's own delta math.
	measure BS_CurrentLiabilities = ABS([CF_AsOf_OtherCurrentLiabilities])
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: c06afe6e-ba9d-4900-9678-e59b149ae5c9

	/// Long-term Liabilities - now correctly month-aware.
	measure BS_LongTermLiabilities = [BS_AsOf_LongTermLiabilities]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: b53b608f-3938-4980-ada0-05a98bb8532f

	/// Equity = Total Assets - Total Liabilities (accounting identity plug). CHANGED 2026-07-07: previously an independent OB-anchor + accrued-Net-Income roll-forward, which could diverge from Assets/Liabilities when GL and P&L don't fully reconcile mid-year. See Management Report data quality note for the April 2026 Inventory finding this surfaced.
	measure BS_Equity =
			-- Equity is derived as the balancing residual of the accounting identity
			-- (Assets = Liabilities + Equity), not as an independent NI roll-forward.
			-- Rationale: an independently-maintained roll-forward (prior anchor + accrued
			-- Net Income) is a second source of truth for the same number and can drift
			-- from Assets/Liabilities if the P&L feed and GL balance postings don't
			-- reconcile perfectly for an in-progress period. Deriving Equity as a plug
			-- guarantees BS_CheckBalance = 0 at every date, by construction.
			[BS_TotalAssets] - [BS_TotalLiabilities]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: 4c969ea8-13bf-43a7-9b90-c21f3bfd120c

	/// Net Working Capital
	measure BS_NetWorkingCapital = [BS_CurrentAssets] - [BS_CurrentLiabilities]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: 9654b768-3a77-41ad-a0b6-708104537792

	/// Current Ratio
	measure BS_CurrentRatio = DIVIDE([BS_CurrentAssets], [BS_CurrentLiabilities], BLANK())
		formatString: 0.00
		displayFolder: Balance Sheet\Ratios
		lineageTag: 7bad59ad-90a4-4e0c-803d-de33d0eced6d

	/// Quick Ratio - use ABS to ensure positive, protect against inventory > current assets
	measure BS_QuickRatio =
			VAR CA = [BS_CurrentAssets]
			VAR Inv = MIN([BS_Inventory], CA * 0.8)
			RETURN DIVIDE(CA - Inv, [BS_CurrentLiabilities], BLANK())
		formatString: 0.00
		displayFolder: Balance Sheet\Ratios
		lineageTag: 25f9a1ee-fac3-44b9-bac7-291eff8634ac

	/// Debt to Equity
	measure BS_DebtToEquity = DIVIDE([BS_TotalLiabilities], [BS_Equity], BLANK())
		formatString: 0.00
		displayFolder: Balance Sheet\Ratios
		lineageTag: 920d0af1-475e-4314-84ab-aabb53442d12

	/// Equity Ratio
	measure BS_EquityRatio = DIVIDE([BS_Equity], [BS_TotalAssets], BLANK())
		formatString: 0.0%
		displayFolder: Balance Sheet\Ratios
		lineageTag: 52838187-7c3f-4fd9-b214-f4512c9d15d0

	/// Debt Ratio
	measure BS_DebtRatio = DIVIDE([BS_TotalLiabilities], [BS_TotalAssets], BLANK())
		formatString: 0.0%
		displayFolder: Balance Sheet\Ratios
		lineageTag: eefd12b2-fdd1-4e26-bafe-288f42626702

	/// CHECK: Assets = Liabilities + Equity. Must = 0.
	measure BS_CheckBalance = [BS_TotalAssets] - [BS_TotalLiabilities] - [BS_Equity]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet
		lineageTag: 9fca81ed-4792-4742-a32a-a206a3dbd000

	/// BS_ReportValue updated for new structure including Spacer rows
	measure BS_ReportValue =
			VAR SelYear   = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			VAR YearEnd   = DATE(SelYear, 12, 31)
			VAR rowLevel  = SELECTEDVALUE(BS_Structure[RowLevel],    "")
			VAR acctName  = SELECTEDVALUE(BS_Structure[AccountName], "")
			VAR TotalAssets   = CALCULATE([BS_TotalAssets],         ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR CurrAssets    = CALCULATE([BS_CurrentAssets],       ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR NonCurrAssets = CALCULATE([BS_NonCurrentAssets],    ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR TotalLiab     = CALCULATE([BS_TotalLiabilities],    ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR CurrLiab      = CALCULATE([BS_CurrentLiabilities],  ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR LTLiab        = CALCULATE([BS_LongTermLiabilities], ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR TotalEquity   = CALCULATE([BS_Equity],              ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR GL_Val = ABS(CALCULATE(SUM(GL_Actual[Amount]), TREATAS({acctName}, Dim_Accounts[AccountName]), ALL(Dim_Date), Dim_Date[Year] <= SelYear))
			VAR OB_Map = SWITCH(acctName, "Cash", 110100, "Prepaid Expenses", 130100, "Machinery & Equipment", 140100, "Buildings", 140200, "Accum. Depreciation", 140300, "Bank Loans", 230100, "Lease Liabilities", 230200, "Share Capital", 310100, "Retained Earnings", 320100, "Current Year Result", 330100, -1)
			VAR OB_Val = ABS(SUMX(FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] = YearEnd && Opening_Balances[OB_Account] = OB_Map), Opening_Balances[OB_Amount]))
			RETURN
			SWITCH(
			    TRUE(),
			    rowLevel IN {"Header", "GroupHeader", "Spacer"} || acctName = "", BLANK(),
			    acctName = "TOTAL ASSETS",               TotalAssets,
			    acctName = "Total Current Assets",        CurrAssets,
			    acctName = "Total Non-current Assets",    NonCurrAssets,
			    acctName = "TOTAL EQUITY",                TotalEquity,
			    acctName = "TOTAL LIABILITIES",           TotalLiab,
			    acctName = "Total Current Liabilities",   CurrLiab,
			    acctName = "Total Long-term Liabilities", LTLiab,
			    acctName = "TOTAL LIABILITIES + EQUITY",  TotalLiab + TotalEquity,
			    OB_Map <> -1,                             OB_Val,
			    GL_Val <> 0,                              GL_Val,
			    BLANK()
			)
		formatString: "€" #,0;-"€" #,0;-
		displayFolder: Balance Sheet
		lineageTag: 3654d42f-05e8-4339-9e62-d9870264f054

	/// IAS 7 Indirect Method: Net Income + D&A + Prepaid Expenses movement. Prepaid delta now uses period-start/period-end (MIN/MAX of selection) instead of DATEADD, so it aggregates correctly at any grain - month, year, or all-time.
	measure CF_OperatingCF =
			VAR NetIncome = [Net Income]
			VAR DA = CALCULATE([Actual], Dim_Accounts[FSGroup] = "D&A")
			VAR MinDate = MIN(Dim_Date[Date])
			VAR MaxDate = MAX(Dim_Date[Date])
			VAR PriorDate = MinDate - 1
			VAR CurPre = CALCULATE([CF_AsOf_PrepaidExpenses], ALL(Dim_Date), Dim_Date[Date] = MaxDate)
			VAR PriorPre = CALCULATE([CF_AsOf_PrepaidExpenses], ALL(Dim_Date), Dim_Date[Date] = PriorDate)
			VAR PreChange = PriorPre - CurPre
			RETURN
			NetIncome + DA + PreChange
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow
		lineageTag: e3239313-b6b8-4919-928b-e6647ae57e87

	/// Investing CF = direct period sum of Machinery & Buildings GL postings (140100/140200), sign-corrected. Excludes 140300 Accumulated Depreciation - that's non-cash and already captured via the D&A add-back in Operating CF.
	measure CF_InvestingCF = -1 * CALCULATE(SUM(GL_Actual[Amount]), Dim_Accounts[Account] IN {"140100", "140200"})
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow
		lineageTag: be57bdcf-94c6-4711-bc29-ac40e61a6238

	/// Financing CF = direct period sum of Bank Loan & Lease Liability GL postings (230100/230200), sign-corrected.
	measure CF_FinancingCF = -1 * CALCULATE(SUM(GL_Actual[Amount]), Dim_Accounts[Account] IN {"230100", "230200"})
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow
		lineageTag: 0876dde9-ba7e-452f-bb7c-eec05299750c

	/// Total net cash movement for the period
	measure CF_NetCashFlow = [CF_OperatingCF] + [CF_InvestingCF] + [CF_FinancingCF]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow
		lineageTag: 2cbdf5cf-c406-40f1-bd86-44f9192e40d4

	/// Closing cash as of the day before the FIRST date in the current filter context. Correct at any grain - single month, full year, or all-time - unlike the prior EOMONTH(MAX(Date)) approach which only worked for single-month selections.
	measure CF_OpeningCash =
			VAR MinDate = MIN(Dim_Date[Date])
			VAR PriorDate = MinDate - 1
			RETURN CALCULATE([CF_ClosingCash], ALL(Dim_Date), Dim_Date[Date] = PriorDate)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow
		lineageTag: abeebb92-d999-41ec-8337-fb054dfab4de

	/// Closing cash = anchor + cumulative Net Income + D&A + Prepaid movement + Investing + Financing, from inception through the selected date. Uses ALL(Dim_Date)+explicit Date filter throughout (never Year/Month Number columns) to stay immune to slicer filter-conflict issues.
	measure CF_ClosingCash =
			VAR MaxDate = MAX(Dim_Date[Date])
			VAR EarliestDate = CALCULATE(MIN(Dim_Date[Date]), ALL(Dim_Date))
			VAR CumNetIncome = CALCULATE([Net Income], FILTER(ALL(Dim_Date), Dim_Date[Date] <= MaxDate))
			VAR CumDA = CALCULATE([Actual], Dim_Accounts[FSGroup] = "D&A", FILTER(ALL(Dim_Date), Dim_Date[Date] <= MaxDate))
			VAR InitialPrepaid = CALCULATE([CF_AsOf_PrepaidExpenses], ALL(Dim_Date), Dim_Date[Date] = EarliestDate)
			VAR CurPrepaid = CALCULATE([CF_AsOf_PrepaidExpenses], ALL(Dim_Date), Dim_Date[Date] = MaxDate)
			VAR PrepaidContribution = InitialPrepaid - CurPrepaid
			VAR CumInvesting = CALCULATE(-1 * SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date] <= MaxDate), Dim_Accounts[Account] IN {"140100", "140200"})
			VAR CumFinancing = CALCULATE(-1 * SUM(GL_Actual[Amount]), FILTER(ALL(Dim_Date), Dim_Date[Date] <= MaxDate), Dim_Accounts[Account] IN {"230100", "230200"})
			RETURN 1027823 + CumNetIncome + CumDA + PrepaidContribution + CumInvesting + CumFinancing
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow
		lineageTag: 409a700e-c2ce-4898-bcdf-3a436ba6de02

	/// Cumulative closing cash balance for trend chart
	measure CF_RunningCash =
			CALCULATE(
			    [CF_ClosingCash],
			    FILTER(
			        ALL(Dim_Date),
			        Dim_Date[Date] <= MAX(Dim_Date[Date])
			    )
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow
		lineageTag: 00984b8a-db48-46c5-98a0-e0a7829522eb

	/// Cash flow as % of revenue. Quality of earnings indicator.
	measure CF_OperatingMargin = DIVIDE([CF_OperatingCF], [Revenue], BLANK())
		formatString: 0.0%
		displayFolder: Cash Flow\Ratios
		lineageTag: b913a786-a6aa-4c82-bf41-ff1b474f622f

	/// Operating CF available after investing. True cash generation.
	measure CF_FreeCashFlow = [CF_OperatingCF] + [CF_InvestingCF]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow\Ratios
		lineageTag: 477a97f5-ae7a-4e18-b5cf-86937efe7508

	/// Quality of earnings: CF vs Net Income. >1x = strong cash conversion. Format updated to show 'x' multiple, avoiding misreading as a percentage.
	measure CF_CashConversionRatio = DIVIDE([CF_OperatingCF], [Net Income], BLANK())
		formatString: 0.00"x"
		displayFolder: Cash Flow\Ratios
		lineageTag: 21c14914-b5ec-408b-852d-9aae019dbc7a

	/// Interest coverage: Operating CF / gross Financial (Interest) Expenses. Corrected to use gross expense, not net Financial Result - netting against Financial Income would overstate true debt-servicing capacity.
	measure CF_CashCoverageRatio =
			DIVIDE(
			    [CF_OperatingCF],
			    ABS([IS_FinancialExpenses]),
			    BLANK()
			)
		formatString: 0.00"x"
		displayFolder: Cash Flow\Ratios
		lineageTag: 9f0c148a-fc41-40ef-b8ee-653b02f4f183

	/// Context-aware value for CF matrix rows. Reads CF_Structure row context.
	measure CF_ReportValue =
			VAR grp = SELECTEDVALUE(CF_Structure[CFGroup])
			VAR line = SELECTEDVALUE(CF_Structure[LineItem])
			
			RETURN
			SWITCH(
			    TRUE(),
			    grp = "TOTAL OPERATING CF",   [CF_OperatingCF],
			    grp = "TOTAL INVESTING CF",   [CF_InvestingCF],
			    grp = "TOTAL FINANCING CF",   [CF_FinancingCF],
			    grp = "NET CASH FLOW",        [CF_NetCashFlow],
			    grp = "Opening Cash Balance", [CF_OpeningCash],
			    grp = "CLOSING CASH BALANCE", [CF_ClosingCash],
			    line = "Net Income",           [Net Income],
			    line = "Depreciation & Amortisation", CALCULATE([Actual], Dim_Accounts[FSGroup] = "D&A"),
			    line = "Impairments", BLANK(),
			    line = "Non-cash Provisions", BLANK(),
			    line = "Change in Accounts Receivable", BLANK(),
			    line = "Change in Inventory", BLANK(),
			    line = "Change in Other Current Liabilities", BLANK(),
			    line = "Change in Other Working Capital", (
			        CALCULATE([CF_AsOf_PrepaidExpenses], DATEADD(Dim_Date[Date], -1, MONTH))
			        - [CF_AsOf_PrepaidExpenses]
			    ),
			    line = "Change in Fixed Assets", [CF_InvestingCF],
			    line = "Change in Bank Loans", -1 * CALCULATE([Actual Amount], Dim_Accounts[Account] = "230100"),
			    line = "Change in Lease Liabilities", -1 * CALCULATE([Actual Amount], Dim_Accounts[Account] = "230200"),
			    BLANK()
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Cash Flow
		lineageTag: 8dc073ca-d75f-4e10-95be-579a1a810371

	/// Year-to-date Revenue
	measure IS_YTD_Revenue = CALCULATE([Revenue], DATESYTD(Dim_Date[Date]))
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement\Time Intelligence
		lineageTag: cacf1635-16fe-4937-967d-87bdf9d35205

	/// Month-to-date Revenue
	measure IS_MTD_Revenue = CALCULATE([Revenue], DATESMTD(Dim_Date[Date]))
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement\Time Intelligence
		lineageTag: 93ebc976-2bae-423b-bf71-f51930b43137

	/// Year-to-date Net Income
	measure IS_YTD_NetIncome = CALCULATE([Net Income], DATESYTD(Dim_Date[Date]))
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement\Time Intelligence
		lineageTag: 10099e02-9c8e-4785-95f1-0e9982ef35e1

	/// Year-to-date EBITDA
	measure IS_YTD_EBITDA = CALCULATE([EBITDA], DATESYTD(Dim_Date[Date]))
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement\Time Intelligence
		lineageTag: 2bc54d4a-cff8-4a14-a2ce-3f953d42786e

	/// EBITDA as % of Revenue
	measure IS_EBITDAMargin = DIVIDE([EBITDA], [Revenue], BLANK())
		formatString: 0.0%
		displayFolder: Income Statement\Margins
		lineageTag: 312a6c63-60e3-4139-bce0-3035ca4b519b

	/// Net Income as % of Revenue
	measure IS_NetMargin = DIVIDE([Net Income], [Revenue], BLANK())
		formatString: 0.0%
		displayFolder: Income Statement\Margins
		lineageTag: 089402a0-adba-443f-b68c-cf854638817c

	/// Gross Profit as % of Revenue
	measure IS_GrossMargin = DIVIDE([Gross Profit], [Revenue], BLANK())
		formatString: 0.0%
		displayFolder: Income Statement\Margins
		lineageTag: 15b87ad2-97c2-4774-a5ff-6c14ddb4c591

	/// YTD Revenue Budget
	measure IS_YTD_BudgetRevenue =
			CALCULATE(
			    [Budget],
			    DATESYTD(Dim_Date[Date]),
			    Dim_Accounts[FSGroup] = "Revenue"
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement\Time Intelligence
		lineageTag: 464c953e-1067-41a5-98bc-49c48eef051b

	/// YTD Revenue variance vs budget
	measure IS_YTD_Variance = [IS_YTD_Revenue] - [IS_YTD_BudgetRevenue]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement\Time Intelligence
		lineageTag: 4f610590-7819-46f8-a7e8-c6b9c6ddd0eb

	/// YTD Revenue variance % vs budget
	measure IS_YTD_Variance_Pct = DIVIDE([IS_YTD_Variance], ABS([IS_YTD_BudgetRevenue]), BLANK())
		formatString: 0.0%
		displayFolder: Income Statement\Time Intelligence
		lineageTag: 317529ec-74b5-4a77-b5d1-61ddc4d3b6dc

	/// Revenue growth vs same period last year
	measure IS_RevenueVsPY =
			VAR CurPeriod = [Revenue]
			VAR PriorYear = CALCULATE([Revenue], SAMEPERIODLASTYEAR(Dim_Date[Date]))
			RETURN DIVIDE(CurPeriod - PriorYear, ABS(PriorYear), BLANK())
		formatString: 0.0%
		displayFolder: Income Statement\Time Intelligence
		lineageTag: 4bc9ce6e-1a99-41ad-915d-f26e04b85453

	/// Full-year revenue forecast based on YTD run rate — year-aware
	measure IS_Forecast =
			VAR SelYear = SELECTEDVALUE(Dim_Date[Year], YEAR(TODAY()))
			VAR MonthsWithData =
			    CALCULATE(
			        DISTINCTCOUNT(Dim_Date[Month Number]),
			        ALL(Dim_Date[Month Number]),
			        Dim_Date[Year] = SelYear
			    )
			VAR YTDRev =
			    CALCULATE(
			        [Revenue],
			        ALL(Dim_Date[Month Number]),
			        Dim_Date[Year] = SelYear
			    )
			RETURN
			IF(
			    MonthsWithData > 0 && MonthsWithData < 12,
			    DIVIDE(YTDRev, MonthsWithData) * 12,
			    YTDRev
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement\Forecast
		lineageTag: 5280c456-633b-40bb-a469-62ac3d70ce99

	/// Full-year forecast gap vs annual budget for selected year
	measure IS_ForecastVsBudget =
			VAR SelYear = SELECTEDVALUE(Dim_Date[Year], YEAR(TODAY()))
			VAR AnnualBudget =
			    CALCULATE(
			        [IS_RevenueBudget],
			        ALL(Dim_Date[Month Number]),
			        Dim_Date[Year] = SelYear
			    )
			RETURN [IS_Forecast] - AnnualBudget
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement\Forecast
		lineageTag: a487e7d3-bb6f-4f57-bff1-cff500d83f73

	/// Rank operating expense accounts for Top-5 cost driver visual. Use in visual filter: value <= 5
	measure IS_Top5CostDriverRank =
			RANKX(
			    ALL(Dim_Accounts[AccountName]),
			    CALCULATE(
			        [Actual],
			        Dim_Accounts[FSGroup] = "Operating Expenses"
			    ),
			    ,
			    DESC,
			    DENSE
			)
		displayFolder: Income Statement\Analytics
		lineageTag: e053f9a2-3ac2-4e91-82a5-c180e3db91e1

	/// Dynamic text commentary for Revenue KPI card
	measure IS_Commentary_Revenue =
			VAR VarPct = [IS_YTD_Variance_Pct]
			VAR Dir    = IF([IS_YTD_Variance] >= 0, "above", "below")
			VAR Icon   = IF([IS_YTD_Variance] >= 0, "▲", "▼")
			RETURN
			IF(
			    ISBLANK(VarPct),
			    "No budget data available.",
			    Icon & " Revenue is "
			    & FORMAT(ABS(VarPct), "0.0%")
			    & " " & Dir & " budget YTD ("
			    & FORMAT([IS_YTD_Revenue], "€ #,0")
			    & " vs " & FORMAT([IS_YTD_BudgetRevenue], "€ #,0") & ")"
			)
		displayFolder: Income Statement\Commentary
		lineageTag: 95d31c3f-a5d2-40a3-b6db-8a575dcbaecd

	/// Dynamic text commentary for EBITDA Margin KPI card
	measure IS_Commentary_EBITDA =
			VAR Margin    = [IS_EBITDAMargin]
			VAR BudMargin = DIVIDE(
			    CALCULATE([Budget], Dim_Accounts[FSGroup] IN {"Revenue","COGS","Operating Expenses"}),
			    CALCULATE([Budget], Dim_Accounts[FSGroup] = "Revenue"),
			    BLANK()
			)
			VAR Gap  = Margin - BudMargin
			VAR Icon = IF(Gap >= 0, "▲", "▼")
			RETURN
			IF(
			    ISBLANK(Margin),
			    "No data available.",
			    Icon & " EBITDA Margin: " & FORMAT(Margin, "0.0%")
			    & IF(NOT ISBLANK(BudMargin),
			        " (target " & FORMAT(BudMargin, "0.0%") & ", gap " & FORMAT(Gap, "+0.0%;-0.0%") & ")",
			        ""
			    )
			)
		displayFolder: Income Statement\Commentary
		lineageTag: f8e7754d-8d7e-4211-b548-898f78ef1d16

	/// Cumulative GL amount for assets up to max selected date
	measure BS_CumulativeActual_Asset =
			CALCULATE(
			    [Actual Amount] * -1,
			    FILTER(ALL(Dim_Date), Dim_Date[Date] <= MAX(Dim_Date[Date]))
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\_Base
		lineageTag: 6a957f78-f0fd-4839-a136-54eb3d9724ff

	/// Cumulative actual for specific account type up to max date
	measure BS_GL_Assets =
			CALCULATE(
			    [Actual Amount] * -1,
			    FILTER(ALL(Dim_Date), Dim_Date[Date] <= MAX(Dim_Date[Date])),
			    Dim_Accounts[AccountType] = "Asset"
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\_Base
		lineageTag: 42a72c7c-ac17-4588-848b-963af3a1fab2

	/// Cumulative GL liabilities up to max date (credit=positive)
	measure BS_GL_Liabilities =
			CALCULATE(
			    [Actual Amount],
			    FILTER(ALL(Dim_Date), Dim_Date[Date] <= MAX(Dim_Date[Date])),
			    Dim_Accounts[AccountType] = "Liability"
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\_Base
		lineageTag: 70e816ea-5517-45d5-b52e-17c6fabbfc5f

	/// Cumulative GL equity up to max date
	measure BS_GL_Equity =
			CALCULATE(
			    [Actual Amount],
			    FILTER(ALL(Dim_Date), Dim_Date[Date] <= MAX(Dim_Date[Date])),
			    Dim_Accounts[AccountType] = "Equity"
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\_Base
		lineageTag: 6d17b714-604c-4a97-a8d6-3eb44b5cb0e8

	/// Cumulative Net Income up to max selected date
	measure BS_CumulativeNetIncome =
			CALCULATE(
			    [Net Income],
			    FILTER(ALL(Dim_Date), Dim_Date[Date] <= MAX(Dim_Date[Date]))
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\_Base
		lineageTag: ec984c2e-dfca-4f8b-b2f2-8624c6c25299

	/// JSON for KPI cards. All values as dot-decimal strings.
	measure KPI_Cards_JSON =
			VAR vRev  = SUBSTITUTE(FORMAT([Revenue],     "#,##0"), ",", ".")
			VAR vGP   = SUBSTITUTE(FORMAT([Gross Profit], "#,##0"), ",", ".")
			VAR vEB   = SUBSTITUTE(FORMAT([EBITDA],       "#,##0"), ",", ".")
			VAR vET   = SUBSTITUTE(FORMAT([EBIT],         "#,##0"), ",", ".")
			VAR vNI   = SUBSTITUTE(FORMAT([Net Income],   "#,##0"), ",", ".")
			RETURN
			"{" &
			  """Revenue"":"    & """" & vRev & """" & "," &
			  """GrossProfit"":" & """" & vGP  & """" & "," &
			  """EBITDA"":"     & """" & vEB  & """" & "," &
			  """EBIT"":"       & """" & vET  & """" & "," &
			  """NetIncome"":"  & """" & vNI  & """" &
			"}"
		displayFolder: JSON Measures
		lineageTag: e177b353-15d9-4942-b296-f1212f9a59bf

	/// JSON for Revenue Trend chart. Monthly data for selected year.
	measure RevenueTrend_JSON =
			VAR SelYear = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			VAR Q = """"
			VAR tbl =
			    ADDCOLUMNS(
			        FILTER(
			            ALL(Dim_Date[Month Number], Dim_Date[MonthShort]),
			            NOT ISBLANK(Dim_Date[Month Number])
			        ),
			        "Rev",
			        CALCULATE([Revenue], Dim_Date[Year] = SelYear)
			    )
			VAR tblFiltered = FILTER(tbl, NOT ISBLANK([Rev]))
			VAR monthLabels =
			    CONCATENATEX(
			        tblFiltered,
			        Q & Dim_Date[MonthShort] & Q,
			        ",",
			        Dim_Date[Month Number], ASC
			    )
			VAR monthValues =
			    CONCATENATEX(
			        tblFiltered,
			        Q & SUBSTITUTE(FORMAT([Rev], "#,##0"), ",", ".") & Q,
			        ",",
			        Dim_Date[Month Number], ASC
			    )
			RETURN
			"{" &
			  """months"":[" & monthLabels & "]," &
			  """values"":[" & monthValues & "]" &
			"}"
		displayFolder: JSON Measures
		lineageTag: a5da42fc-48c2-473d-bbf6-31b38204c501

	/// JSON for EBITDA vs Net Income chart. Monthly data for selected year.
	measure EBITDA_vs_NetIncome_JSON =
			VAR SelYear = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			VAR Q = """"
			VAR tbl =
			    ADDCOLUMNS(
			        FILTER(
			            ALL(Dim_Date[Month Number], Dim_Date[MonthShort]),
			            NOT ISBLANK(Dim_Date[Month Number])
			        ),
			        "EB", CALCULATE([EBITDA],    Dim_Date[Year] = SelYear),
			        "NI", CALCULATE([Net Income], Dim_Date[Year] = SelYear)
			    )
			VAR tblF = FILTER(tbl, NOT ISBLANK([EB]))
			VAR monthLabels = CONCATENATEX(tblF, Q & Dim_Date[MonthShort] & Q, ",", Dim_Date[Month Number], ASC)
			VAR ebitdaVals  = CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([EB], "#,##0"), ",", ".") & Q, ",", Dim_Date[Month Number], ASC)
			VAR niVals      = CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([NI], "#,##0"), ",", ".") & Q, ",", Dim_Date[Month Number], ASC)
			RETURN
			"{" &
			  """months"":["  & monthLabels & "]," &
			  """ebitda"":["  & ebitdaVals  & "]," &
			  """netincome"":[" & niVals    & "]" &
			"}"
		displayFolder: JSON Measures
		lineageTag: 0289fd5d-8867-47ba-b716-27055e82d40a

	/// JSON for Expense Breakdown donut chart.
	measure ExpenseBreakdown_JSON =
			VAR Q = """"
			VAR tbl =
			    ADDCOLUMNS(
			        FILTER(
			            ALL(Dim_Accounts[FSSubgroup]),
			            Dim_Accounts[FSSubgroup] IN {
			                "Personnel", "Administrative",
			                "Facilities", "Commercial", "Technology"
			            }
			        ),
			        "Val", CALCULATE([Actual], Dim_Accounts[FSGroup] = "Operating Expenses")
			    )
			VAR labelsList = CONCATENATEX(tbl, Q & Dim_Accounts[FSSubgroup] & Q, ",")
			VAR valsList   = CONCATENATEX(tbl, Q & SUBSTITUTE(FORMAT([Val], "#,##0"), ",", ".") & Q, ",")
			RETURN
			"{" &
			  """labels"":[" & labelsList & "]," &
			  """values"":[" & valsList   & "]" &
			"}"
		displayFolder: JSON Measures
		lineageTag: 4f91cbcc-bef1-4835-aae2-d52b7ec5ff48

	/// JSON for Income Statement matrix table. Monthly columns, 6 P&L rows.
	measure IncomeStatementMatrix_JSON =
			VAR SelYear = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			VAR Q = """"
			VAR tbl =
			    ADDCOLUMNS(
			        FILTER(
			            ALL(Dim_Date[Month Number], Dim_Date[MonthShort]),
			            NOT ISBLANK(Dim_Date[Month Number])
			        ),
			        "vRev", CALCULATE([Revenue],      Dim_Date[Year] = SelYear),
			        "vCOG", CALCULATE(CALCULATE([Actual], Dim_Accounts[FSGroup]="COGS"), Dim_Date[Year] = SelYear),
			        "vOpX", CALCULATE(CALCULATE([Actual], Dim_Accounts[FSGroup]="Operating Expenses"), Dim_Date[Year] = SelYear),
			        "vEB",  CALCULATE([EBITDA],        Dim_Date[Year] = SelYear),
			        "vET",  CALCULATE([EBIT],          Dim_Date[Year] = SelYear),
			        "vNI",  CALCULATE([Net Income],    Dim_Date[Year] = SelYear)
			    )
			VAR tblF = FILTER(tbl, NOT ISBLANK([vRev]))
			VAR mths = CONCATENATEX(tblF, Q & Dim_Date[MonthShort] & Q, ",", Dim_Date[Month Number], ASC)
			VAR rRev = Q & "Revenue"             & Q & ":[" & CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vRev],"#,##0"),",",".") & Q, ",", Dim_Date[Month Number], ASC) & "]"
			VAR rCOG = Q & "COGS"                & Q & ":[" & CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vCOG],"#,##0"),",",".") & Q, ",", Dim_Date[Month Number], ASC) & "]"
			VAR rOpX = Q & "Operating Expenses"  & Q & ":[" & CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vOpX],"#,##0"),",",".") & Q, ",", Dim_Date[Month Number], ASC) & "]"
			VAR rEB  = Q & "EBITDA"              & Q & ":[" & CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vEB], "#,##0"),",",".") & Q, ",", Dim_Date[Month Number], ASC) & "]"
			VAR rET  = Q & "EBIT"                & Q & ":[" & CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vET], "#,##0"),",",".") & Q, ",", Dim_Date[Month Number], ASC) & "]"
			VAR rNI  = Q & "Net Income"          & Q & ":[" & CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vNI], "#,##0"),",",".") & Q, ",", Dim_Date[Month Number], ASC) & "]"
			RETURN
			"{" &
			  """months"":[" & mths & "]," &
			  """rows"":[" &
			    "{""name"":" & rRev & "}," &
			    "{""name"":" & rCOG & "}," &
			    "{""name"":" & rOpX & "}," &
			    "{""name"":" & rEB  & "}," &
			    "{""name"":" & rET  & "}," &
			    "{""name"":" & rNI  & "}" &
			  "]" &
			"}"
		displayFolder: JSON Measures
		lineageTag: 30ccb6d3-e315-4b49-83a0-cd965baaced6

	/// Executive Summary KPI block - Revenue, EBITDA, Net Income, Total Assets, Cash, Operating CF with YoY deltas
	measure ES_KPI_JSON =
			VAR Q = """"
			VAR SelYear   = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			VAR PrevYear  = SelYear - 1
			
			VAR vRev      = [Revenue]
			VAR vRevPY    = CALCULATE([Revenue],   Dim_Date[Year] = PrevYear)
			VAR vRevDelta = IF(vRevPY <> 0, DIVIDE(vRev - vRevPY, ABS(vRevPY)), BLANK())
			
			VAR vEB       = [EBITDA]
			VAR vEBPY     = CALCULATE([EBITDA],    Dim_Date[Year] = PrevYear)
			VAR vEBDelta  = IF(vEBPY <> 0, DIVIDE(vEB - vEBPY, ABS(vEBPY)), BLANK())
			
			VAR vNI       = [Net Income]
			VAR vNIPY     = CALCULATE([Net Income],Dim_Date[Year] = PrevYear)
			VAR vNIDelta  = IF(vNIPY <> 0, DIVIDE(vNI - vNIPY, ABS(vNIPY)), BLANK())
			
			VAR vAssets   = [BS_TotalAssets]
			VAR vCash     = [BS_Cash]
			VAR vEquity   = [BS_Equity]
			VAR vLiab     = [BS_TotalLiabilities]
			
			VAR vOCF      = [CF_OperatingCF]
			VAR vFCF      = [CF_FreeCashFlow]
			
			VAR vGM       = [IS_GrossMargin]
			VAR vEM       = [IS_EBITDAMargin]
			VAR vNM       = [IS_NetMargin]
			
			VAR vVAR      = [VAR]
			VAR vVARpct   = [VAR %]
			
			VAR vCR       = [BS_CurrentRatio]
			VAR vDE       = [BS_DebtToEquity]
			
			VAR fmt = "#,##0"
			VAR fmtPct = "0.0%"
			
			RETURN
			"{" &
			  Q & "year"        & Q & ":"  & SelYear & "," &
			  Q & "revenue"     & Q & ":"  & Q & SUBSTITUTE(FORMAT(vRev,  fmt),",",".") & Q & "," &
			  Q & "revDelta"    & Q & ":"  & Q & FORMAT(vRevDelta, "0.0%") & Q & "," &
			  Q & "ebitda"      & Q & ":"  & Q & SUBSTITUTE(FORMAT(vEB,   fmt),",",".") & Q & "," &
			  Q & "ebitdaDelta" & Q & ":"  & Q & FORMAT(vEBDelta,  "0.0%") & Q & "," &
			  Q & "netIncome"   & Q & ":"  & Q & SUBSTITUTE(FORMAT(vNI,   fmt),",",".") & Q & "," &
			  Q & "niDelta"     & Q & ":"  & Q & FORMAT(vNIDelta,  "0.0%") & Q & "," &
			  Q & "totalAssets" & Q & ":"  & Q & SUBSTITUTE(FORMAT(vAssets,fmt),",",".") & Q & "," &
			  Q & "cash"        & Q & ":"  & Q & SUBSTITUTE(FORMAT(vCash,  fmt),",",".") & Q & "," &
			  Q & "equity"      & Q & ":"  & Q & SUBSTITUTE(FORMAT(vEquity,fmt),",",".") & Q & "," &
			  Q & "liabilities" & Q & ":"  & Q & SUBSTITUTE(FORMAT(vLiab,  fmt),",",".") & Q & "," &
			  Q & "operatingCF" & Q & ":"  & Q & SUBSTITUTE(FORMAT(vOCF,  fmt),",",".") & Q & "," &
			  Q & "freeCashFlow"& Q & ":"  & Q & SUBSTITUTE(FORMAT(vFCF,  fmt),",",".") & Q & "," &
			  Q & "grossMargin" & Q & ":"  & Q & FORMAT(vGM, "0.0%") & Q & "," &
			  Q & "ebitdaMargin"& Q & ":"  & Q & FORMAT(vEM, "0.0%") & Q & "," &
			  Q & "netMargin"   & Q & ":"  & Q & FORMAT(vNM, "0.0%") & Q & "," &
			  Q & "budgetVAR"   & Q & ":"  & Q & SUBSTITUTE(FORMAT(vVAR, fmt),",",".") & Q & "," &
			  Q & "budgetVARpct"& Q & ":"  & Q & FORMAT(vVARpct, "0.0%") & Q & "," &
			  Q & "currentRatio"& Q & ":"  & Q & FORMAT(vCR, "0.00") & Q & "," &
			  Q & "debtToEquity"& Q & ":"  & Q & FORMAT(vDE, "0.00") & Q &
			"}"
		displayFolder: JSON Measures
		lineageTag: 9ff46dbd-789f-499d-81bb-cdccbe535f23

	/// Budget vs Actual waterfall data by year for Executive Summary
	measure ES_WaterfallBVA_JSON =
			VAR Q = """"
			VAR tbl =
			    ADDCOLUMNS(
			        SUMMARIZE(ALL(Dim_Date), Dim_Date[Year]),
			        "vAct", CALCULATE([Revenue], ALL(Dim_Date[Month Number], Dim_Date[MonthShort])),
			        "vBud", CALCULATE([Budget],  ALL(Dim_Date[Month Number], Dim_Date[MonthShort]))
			    )
			VAR tblF = FILTER(tbl, NOT ISBLANK([vAct]) && Dim_Date[Year] >= 2023)
			VAR yrs  = CONCATENATEX(tblF, Q & FORMAT(Dim_Date[Year],"0") & Q, ",", Dim_Date[Year], ASC)
			VAR acts = CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vAct],"#,##0"),",",".") & Q, ",", Dim_Date[Year], ASC)
			VAR buds = CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vBud],"#,##0"),",",".") & Q, ",", Dim_Date[Year], ASC)
			RETURN
			"{" &
			  Q & "years"   & Q & ":[" & yrs  & "]," &
			  Q & "actual"  & Q & ":[" & acts & "]," &
			  Q & "budget"  & Q & ":[" & buds & "]"
			& "}"
		displayFolder: JSON Measures
		lineageTag: cab043d8-2ab6-49db-94a1-32b998d4341d

	/// Balance Sheet snapshot for Executive Summary - Assets, Liabilities, Equity by year
	measure ES_BSSnapshot_JSON =
			VAR Q = """"
			VAR tbl =
			    ADDCOLUMNS(
			        SUMMARIZE(ALL(Dim_Date), Dim_Date[Year]),
			        "vA",  CALCULATE([BS_TotalAssets]),
			        "vL",  CALCULATE([BS_TotalLiabilities]),
			        "vE",  CALCULATE([BS_Equity])
			    )
			VAR tblF = FILTER(tbl, NOT ISBLANK([vA]) && Dim_Date[Year] >= 2023)
			VAR yrs  = CONCATENATEX(tblF, Q & FORMAT(Dim_Date[Year],"0") & Q, ",", Dim_Date[Year], ASC)
			VAR aVals = CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vA],"#,##0"),",",".") & Q, ",", Dim_Date[Year], ASC)
			VAR lVals = CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vL],"#,##0"),",",".") & Q, ",", Dim_Date[Year], ASC)
			VAR eVals = CONCATENATEX(tblF, Q & SUBSTITUTE(FORMAT([vE],"#,##0"),",",".") & Q, ",", Dim_Date[Year], ASC)
			RETURN
			"{" &
			  Q & "years"       & Q & ":[" & yrs   & "]," &
			  Q & "assets"      & Q & ":[" & aVals & "]," &
			  Q & "liabilities" & Q & ":[" & lVals & "]," &
			  Q & "equity"      & Q & ":[" & eVals & "]"
			& "}"
		displayFolder: JSON Measures
		lineageTag: 3b33b210-7504-4066-ad43-f02e8bbe0c81

	/// Executive Summary HTML page - full CFO-level dashboard rendered via HTML Content visual
	measure ES_HTML =
			VAR Q = """"
			VAR SelYear   = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			VAR PrevYear  = SelYear - 1
			
			VAR vRev      = [Revenue]
			VAR vRevPY    = CALCULATE([Revenue],    Dim_Date[Year] = PrevYear)
			VAR vRevGrw   = DIVIDE(vRev - vRevPY, ABS(vRevPY), BLANK())
			
			VAR vEB       = [EBITDA]
			VAR vEBM      = [IS_EBITDAMargin]
			VAR vEBPY     = CALCULATE([EBITDA],    Dim_Date[Year] = PrevYear)
			VAR vEBGrw    = DIVIDE(vEB - vEBPY, ABS(vEBPY), BLANK())
			
			VAR vNI       = [Net Income]
			VAR vNIM      = [IS_NetMargin]
			VAR vNIPY     = CALCULATE([Net Income], Dim_Date[Year] = PrevYear)
			VAR vNIGrw    = DIVIDE(vNI - vNIPY, ABS(vNIPY), BLANK())
			
			VAR vGM       = [IS_GrossMargin]
			VAR vAssets   = [BS_TotalAssets]
			VAR vCash     = [BS_Cash]
			VAR vEquity   = [BS_Equity]
			VAR vLiab     = [BS_TotalLiabilities]
			VAR vOCF      = [CF_OperatingCF]
			VAR vFCF      = [CF_FreeCashFlow]
			VAR vCR       = [BS_CurrentRatio]
			VAR vDE       = [BS_DebtToEquity]
			VAR vVAR      = [VAR]
			VAR vVARpct   = [VAR %]
			VAR vBud      = [Budget]
			
			VAR fmt = "#,##0"
			
			VAR sRev    = SUBSTITUTE(FORMAT(vRev,    fmt), ",", ".")
			VAR sEB     = SUBSTITUTE(FORMAT(vEB,     fmt), ",", ".")
			VAR sNI     = SUBSTITUTE(FORMAT(vNI,     fmt), ",", ".")
			VAR sAssets = SUBSTITUTE(FORMAT(vAssets, fmt), ",", ".")
			VAR sCash   = SUBSTITUTE(FORMAT(vCash,   fmt), ",", ".")
			VAR sOCF    = SUBSTITUTE(FORMAT(vOCF,    fmt), ",", ".")
			VAR sFCF    = SUBSTITUTE(FORMAT(vFCF,    fmt), ",", ".")
			VAR sVAR    = SUBSTITUTE(FORMAT(vVAR,    fmt), ",", ".")
			VAR sBud    = SUBSTITUTE(FORMAT(vBud,    fmt), ",", ".")
			VAR sCR     = FORMAT(vCR,   "0.00")
			VAR sDE     = FORMAT(vDE,   "0.00")
			VAR sGM     = FORMAT(vGM,   "0.0%")
			VAR sEM     = FORMAT(vEBM,  "0.0%")
			VAR sNM     = FORMAT(vNIM,  "0.0%")
			VAR sVARpct = FORMAT(vVARpct, "+0.0%;-0.0%")
			VAR sRevGrw = FORMAT(vRevGrw, "+0.0%;-0.0%")
			VAR sEBGrw  = FORMAT(vEBGrw,  "+0.0%;-0.0%")
			VAR sNIGrw  = FORMAT(vNIGrw,  "+0.0%;-0.0%")
			
			VAR niColor  = IF(vNI  >= 0, "#4CAF50", "#C00000")
			VAR varColor = IF(vVAR >= 0, "#4CAF50", "#C00000")
			VAR ocfColor = IF(vOCF >= 0, "#4CAF50", "#C00000")
			VAR revArrow = IF(vRevGrw >= 0, "▲", "▼")
			VAR ebArrow  = IF(vEBGrw  >= 0, "▲", "▼")
			VAR niArrow  = IF(vNIGrw  >= 0, "▲", "▼")
			VAR varArrow = IF(vVAR    >= 0, "▲", "▼")
			
			VAR commentary = [IS_Commentary_Revenue]
			
			RETURN
			"<style>
			  *{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',sans-serif}
			  body{background:#000;color:#fff;padding:10px;height:100vh;overflow:hidden}
			  .header{display:flex;align-items:center;justify-content:space-between;padding:6px 12px;border-bottom:1px solid #C00000;margin-bottom:10px}
			  .header h1{font-size:14px;font-weight:700;letter-spacing:2px;color:#fff;text-transform:uppercase}
			  .header .period{font-size:11px;color:#aaa;letter-spacing:1px}
			  .header .entity{font-size:11px;color:#C00000;font-weight:600;letter-spacing:1px}
			  .grid{display:grid;grid-template-columns:repeat(6,1fr);gap:6px;margin-bottom:8px}
			  .kpi{background:#111;border:1px solid #222;border-radius:4px;padding:8px 10px;position:relative;overflow:hidden}
			  .kpi::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:#C00000}
			  .kpi-label{font-size:9px;color:#888;text-transform:uppercase;letter-spacing:1px;margin-bottom:2px}
			  .kpi-value{font-size:14px;font-weight:700;color:#fff;letter-spacing:-0.5px}
			  .kpi-delta{font-size:9px;margin-top:2px;font-weight:600}
			  .kpi-sub{font-size:9px;color:#666;margin-top:1px}
			  .section-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:8px}
			  .panel{background:#111;border:1px solid #222;border-radius:4px;padding:10px}
			  .panel-title{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#C00000;border-bottom:1px solid #1a1a1a;padding-bottom:4px;margin-bottom:8px}
			  .ratio-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px}
			  .ratio-item{padding:5px 7px;background:#0a0a0a;border-radius:3px;border-left:2px solid #333}
			  .ratio-label{font-size:8px;color:#666;text-transform:uppercase;letter-spacing:0.8px}
			  .ratio-value{font-size:13px;font-weight:700;color:#fff;margin-top:1px}
			  .bva-row{display:flex;align-items:center;justify-content:space-between;padding:4px 0;border-bottom:1px solid #1a1a1a;font-size:10px}
			  .bva-label{color:#888;width:70px}
			  .bva-bar-wrap{flex:1;margin:0 8px;height:6px;background:#1a1a1a;border-radius:3px;overflow:hidden}
			  .bva-bar{height:100%;border-radius:3px}
			  .bva-val{color:#fff;font-weight:600;min-width:60px;text-align:right;font-size:9px}
			  .cf-item{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid #111;font-size:10px}
			  .cf-label{color:#888}
			  .cf-val{font-weight:600}
			  .commentary{background:#0a0a0a;border:1px solid #1a1a1a;border-left:3px solid #C00000;border-radius:3px;padding:6px 10px;font-size:9px;color:#aaa;line-height:1.5}
			  .green{color:#4CAF50}.red{color:#C00000}.white{color:#fff}
			  .full-row{grid-column:1/-1}
			</style>
			<body>
			  <div class='header'>
			    <div>
			      <div class='entity'>CC MODEL SA — IT01</div>
			      <h1>Executive Summary</h1>
			    </div>
			    <div class='period'>FY " & FORMAT(SelYear,"0") & " &nbsp;|&nbsp; Jan 2023 – Apr 2026</div>
			  </div>
			
			  <div class='grid'>
			    <div class='kpi'>
			      <div class='kpi-label'>Revenue</div>
			      <div class='kpi-value'>€ " & sRev & "</div>
			      <div class='kpi-delta' style='color:" & IF(vRevGrw>=0,"#4CAF50","#C00000") & "'>" & revArrow & " " & sRevGrw & " vs PY</div>
			      <div class='kpi-sub'>Gross Margin: " & sGM & "</div>
			    </div>
			    <div class='kpi'>
			      <div class='kpi-label'>EBITDA</div>
			      <div class='kpi-value'>€ " & sEB & "</div>
			      <div class='kpi-delta' style='color:" & IF(vEBGrw>=0,"#4CAF50","#C00000") & "'>" & ebArrow & " " & sEBGrw & " vs PY</div>
			      <div class='kpi-sub'>Margin: " & sEM & "</div>
			    </div>
			    <div class='kpi'>
			      <div class='kpi-label'>Net Income</div>
			      <div class='kpi-value' style='color:" & niColor & "'>€ " & sNI & "</div>
			      <div class='kpi-delta' style='color:" & IF(vNIGrw>=0,"#4CAF50","#C00000") & "'>" & niArrow & " " & sNIGrw & " vs PY</div>
			      <div class='kpi-sub'>Net Margin: " & sNM & "</div>
			    </div>
			    <div class='kpi'>
			      <div class='kpi-label'>Total Assets</div>
			      <div class='kpi-value'>€ " & sAssets & "</div>
			      <div class='kpi-delta' style='color:#888'>Equity: € " & SUBSTITUTE(FORMAT(vEquity,fmt),",",".") & "</div>
			      <div class='kpi-sub'>Liabilities: € " & SUBSTITUTE(FORMAT(vLiab,fmt),",",".") & "</div>
			    </div>
			    <div class='kpi'>
			      <div class='kpi-label'>Cash Balance</div>
			      <div class='kpi-value'>€ " & sCash & "</div>
			      <div class='kpi-delta' style='color:" & ocfColor & "'>OCF: € " & sOCF & "</div>
			      <div class='kpi-sub'>FCF: € " & sFCF & "</div>
			    </div>
			    <div class='kpi'>
			      <div class='kpi-label'>Budget Variance</div>
			      <div class='kpi-value' style='color:" & varColor & "'>€ " & sVAR & "</div>
			      <div class='kpi-delta' style='color:" & varColor & "'>" & varArrow & " " & sVARpct & " vs Budget</div>
			      <div class='kpi-sub'>Budget: € " & sBud & "</div>
			    </div>
			  </div>
			
			  <div class='section-row'>
			    <div class='panel'>
			      <div class='panel-title'>Financial Ratios</div>
			      <div class='ratio-grid'>
			        <div class='ratio-item'><div class='ratio-label'>Current Ratio</div><div class='ratio-value' style='color:" & IF(vCR>=1.5,"#4CAF50","#C00000") & "'>" & sCR & "</div></div>
			        <div class='ratio-item'><div class='ratio-label'>Debt / Equity</div><div class='ratio-value' style='color:" & IF(vDE<=1,"#4CAF50","#C00000") & "'>" & sDE & "</div></div>
			        <div class='ratio-item'><div class='ratio-label'>Gross Margin</div><div class='ratio-value'>" & sGM & "</div></div>
			        <div class='ratio-item'><div class='ratio-label'>EBITDA Margin</div><div class='ratio-value'>" & sEM & "</div></div>
			        <div class='ratio-item'><div class='ratio-label'>Net Margin</div><div class='ratio-value' style='color:" & IF(vNIM>=0,"#4CAF50","#C00000") & "'>" & sNM & "</div></div>
			        <div class='ratio-item'><div class='ratio-label'>OCF Margin</div><div class='ratio-value' style='color:" & IF(vOCF>=0,"#4CAF50","#C00000") & "'>" & FORMAT(DIVIDE(vOCF,vRev),"0.0%") & "</div></div>
			      </div>
			    </div>
			
			    <div class='panel'>
			      <div class='panel-title'>Budget vs Actual</div>
			      <div class='bva-row'>
			        <div class='bva-label'>Actual</div>
			        <div class='bva-bar-wrap'><div class='bva-bar' style='width:90%;background:#C00000'></div></div>
			        <div class='bva-val'>€ " & sRev & "</div>
			      </div>
			      <div class='bva-row'>
			        <div class='bva-label'>Budget</div>
			        <div class='bva-bar-wrap'><div class='bva-bar' style='width:" & FORMAT(DIVIDE(vBud,vRev)*90,"0") & "%;background:#555'></div></div>
			        <div class='bva-val'>€ " & sBud & "</div>
			      </div>
			      <div class='bva-row' style='border:none;margin-top:4px'>
			        <div class='bva-label'>Variance</div>
			        <div class='bva-bar-wrap'></div>
			        <div class='bva-val' style='color:" & varColor & "'>" & sVARpct & "</div>
			      </div>
			      <div style='margin-top:6px;padding-top:6px;border-top:1px solid #1a1a1a'>
			        <div class='commentary'>" & commentary & "</div>
			      </div>
			    </div>
			
			    <div class='panel'>
			      <div class='panel-title'>Cash Flow Summary</div>
			      <div class='cf-item'><div class='cf-label'>Operating CF</div><div class='cf-val' style='color:" & ocfColor & "'>€ " & sOCF & "</div></div>
			      <div class='cf-item'><div class='cf-label'>Investing CF</div><div class='cf-val' style='color:#aaa'>€ " & SUBSTITUTE(FORMAT([CF_InvestingCF],fmt),",",".") & "</div></div>
			      <div class='cf-item'><div class='cf-label'>Financing CF</div><div class='cf-val' style='color:#aaa'>€ " & SUBSTITUTE(FORMAT([CF_FinancingCF],fmt),",",".") & "</div></div>
			      <div class='cf-item' style='border-bottom:1px solid #C00000;padding-bottom:5px;margin-bottom:4px'>
			        <div class='cf-label'>Net Cash Flow</div>
			        <div class='cf-val' style='color:" & IF([CF_NetCashFlow]>=0,"#4CAF50","#C00000") & "'>€ " & SUBSTITUTE(FORMAT([CF_NetCashFlow],fmt),",",".") & "</div>
			      </div>
			      <div class='cf-item'><div class='cf-label' style='color:#C00000;font-weight:700'>Closing Cash</div><div class='cf-val' style='color:#fff;font-size:12px'>€ " & SUBSTITUTE(FORMAT([CF_ClosingCash],fmt),",",".") & "</div></div>
			      <div class='cf-item'><div class='cf-label'>Free Cash Flow</div><div class='cf-val' style='color:" & IF(vFCF>=0,"#4CAF50","#C00000") & "'>€ " & sFCF & "</div></div>
			    </div>
			  </div>
			</body>"
		displayFolder: JSON Measures
		lineageTag: 50bd0b0a-ce4f-4cbd-82b1-8f897376623f

	/// Days Sales Outstanding
	measure BS_DSO = DIVIDE([BS_AccountsReceivable], [Revenue] / 365, BLANK())
		formatString: 0.0
		displayFolder: Balance Sheet\Working Capital
		lineageTag: a544287a-c80c-4d0d-9056-6496b5463de2

	/// Days Payable Outstanding
	measure BS_DPO = DIVIDE([BS_CurrentLiabilities], CALCULATE([Actual], Dim_Accounts[FSGroup] = "COGS") / 365, BLANK())
		formatString: 0.0
		displayFolder: Balance Sheet\Working Capital
		lineageTag: 626594fb-2e3e-4689-a0b9-bd23f54dc977

	/// Net Debt — Total Liabilities minus Cash
	measure BS_NetDebt = [BS_TotalLiabilities] - [BS_Cash]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\Working Capital
		lineageTag: 31bfcbfe-7cc6-4245-a2b5-dd0c380147dd

	/// NWC as % of Total Assets
	measure BS_NWC_Pct = DIVIDE([BS_NetWorkingCapital], [BS_TotalAssets], BLANK())
		formatString: 0.0%
		displayFolder: Balance Sheet\Working Capital
		lineageTag: c6f178e3-e18e-4404-93f3-fe442a19a87d

	/// Total Assets prior year
	measure BS_TotalAssets_PY = VAR PrevYear = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year])) - 1 RETURN CALCULATE([BS_TotalAssets], Dim_Date[Year] = PrevYear)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\YoY
		lineageTag: 42c4ef58-2742-40c9-ad6d-c82fea524726

	/// Total Assets YoY growth %
	measure BS_TotalAssets_YoY = DIVIDE([BS_TotalAssets] - [BS_TotalAssets_PY], ABS([BS_TotalAssets_PY]), BLANK())
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Balance Sheet\YoY
		lineageTag: 21d67132-edc8-42d4-a42f-17ce55d8ddc8

	/// Total Liabilities prior year
	measure BS_TotalLiabilities_PY = VAR PrevYear = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year])) - 1 RETURN CALCULATE([BS_TotalLiabilities], Dim_Date[Year] = PrevYear)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\YoY
		lineageTag: 9601a9cd-fc6f-4086-ac91-30a525c6e844

	/// Total Liabilities YoY change %
	measure BS_TotalLiabilities_YoY = DIVIDE([BS_TotalLiabilities] - [BS_TotalLiabilities_PY], ABS([BS_TotalLiabilities_PY]), BLANK())
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Balance Sheet\YoY
		lineageTag: 104e42fe-a1eb-480b-bd11-edd9ff3d2834

	/// Equity prior year
	measure BS_Equity_PY = VAR PrevYear = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year])) - 1 RETURN CALCULATE([BS_Equity], Dim_Date[Year] = PrevYear)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\YoY
		lineageTag: 9e1c1517-49cc-4d3c-830e-b869c23a1f5d

	/// Equity YoY growth %
	measure BS_Equity_YoY = DIVIDE([BS_Equity] - [BS_Equity_PY], ABS([BS_Equity_PY]), BLANK())
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Balance Sheet\YoY
		lineageTag: 0ed2e99f-79af-47e2-8e65-53725d08e16f

	/// Current Assets as % of Total Assets
	measure BS_CurrentAssets_Pct = DIVIDE([BS_CurrentAssets], [BS_TotalAssets], BLANK())
		formatString: 0.0%
		displayFolder: Balance Sheet\Ratios
		lineageTag: d24157fa-c440-4e5d-a9ca-af158a831a4c

	/// Non-current Assets as % of Total Assets
	measure BS_NonCurrentAssets_Pct = DIVIDE([BS_NonCurrentAssets], [BS_TotalAssets], BLANK())
		formatString: 0.0%
		displayFolder: Balance Sheet\Ratios
		lineageTag: 2073205e-dda6-4a10-9cec-3c6ff55e5b2c

	/// Current Liabilities as % of Total Assets
	measure BS_CurrentLiabilities_Pct = DIVIDE([BS_CurrentLiabilities], [BS_TotalAssets], BLANK())
		formatString: 0.0%
		displayFolder: Balance Sheet\Ratios
		lineageTag: 33816104-baf5-4fde-9e9b-d1347e16b598

	/// Long-term Liabilities as % of Total Assets
	measure BS_LongTermLiabilities_Pct = DIVIDE([BS_LongTermLiabilities], [BS_TotalAssets], BLANK())
		formatString: 0.0%
		displayFolder: Balance Sheet\Ratios
		lineageTag: b2b405c3-e17f-4cc0-b329-3a7c2227b325

	/// Equity as % of Total Assets
	measure BS_Equity_Pct = DIVIDE([BS_Equity], [BS_TotalAssets], BLANK())
		formatString: 0.0%
		displayFolder: Balance Sheet\Ratios
		lineageTag: 78c303b3-c59c-42b8-8fc5-70fdbea3ceb7

	/// Current Ratio healthy minimum threshold
	measure BS_CurrentRatio_Target = 1.5
		formatString: 0.00
		displayFolder: Balance Sheet\Targets
		lineageTag: 2c12b444-4cbd-4876-a742-1032ce32b01c

	/// Debt Ratio conservative maximum
	measure BS_DebtRatio_Target = 0.5
		formatString: 0.00
		displayFolder: Balance Sheet\Targets
		lineageTag: d82c4536-de52-4da8-9350-53c7dfed1d8b

	/// Equity Ratio minimum threshold
	measure BS_EquityRatio_Target = 0.5
		formatString: 0.00
		displayFolder: Balance Sheet\Targets
		lineageTag: e54fcaf3-a394-4b40-a2f9-b3dfbd85ebf1

	/// D/E Ratio maximum comfortable threshold
	measure BS_DebtToEquity_Target = 1.0
		formatString: 0.00
		displayFolder: Balance Sheet\Targets
		lineageTag: a34331d0-6512-4318-aec0-19ae478a7c5a

	/// Quick Ratio minimum threshold
	measure BS_QuickRatio_Target = 1.0
		formatString: 0.00
		displayFolder: Balance Sheet\Targets
		lineageTag: 2db8f3a6-3dca-43a0-a55a-657e36a4e9a9

	/// BS value for selected year - responds to Year slicer
	measure BS_Selected =
			VAR SelYear      = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			VAR YearEnd      = DATE(SelYear, 12, 31)
			VAR rowLevel     = SELECTEDVALUE(BS_Structure[RowLevel],    "")
			VAR acctName     = SELECTEDVALUE(BS_Structure[AccountName], "")
			VAR TotalAssets   = CALCULATE([BS_TotalAssets],         ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR CurrAssets    = CALCULATE([BS_CurrentAssets],       ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR NonCurrAssets = CALCULATE([BS_NonCurrentAssets],    ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR TotalLiab     = CALCULATE([BS_TotalLiabilities],    ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR CurrLiab      = CALCULATE([BS_CurrentLiabilities],  ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR LTLiab        = CALCULATE([BS_LongTermLiabilities], ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR TotalEquity   = CALCULATE([BS_Equity],              ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR GL_Val        = ABS(CALCULATE(SUM(GL_Actual[Amount]), TREATAS({acctName}, Dim_Accounts[AccountName]), ALL(Dim_Date), Dim_Date[Year] <= SelYear))
			VAR OB_Map        = SWITCH(acctName, "Cash", 110100, "Prepaid Expenses", 130100, "Machinery & Equipment", 140100, "Buildings", 140200, "Accum. Depreciation", 140300, "Bank Loans", 230100, "Lease Liabilities", 230200, "Share Capital", 310100, "Retained Earnings", 320100, "Current Year Result", 330100, -1)
			VAR OB_Val        = ABS(SUMX(FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] = YearEnd && Opening_Balances[OB_Account] = OB_Map), Opening_Balances[OB_Amount]))
			RETURN
			SWITCH(
			    TRUE(),
			    rowLevel IN {"Header", "GroupHeader"} || acctName = "", BLANK(),
			    acctName = "TOTAL ASSETS",               TotalAssets,
			    acctName = "Total Current Assets",        CurrAssets,
			    acctName = "Total Non-current Assets",    NonCurrAssets,
			    acctName = "TOTAL EQUITY",                TotalEquity,
			    acctName = "TOTAL LIABILITIES",           TotalLiab,
			    acctName = "Total Current Liabilities",   CurrLiab,
			    acctName = "Total Long-term Liabilities", LTLiab,
			    acctName = "TOTAL LIABILITIES + EQUITY",  TotalLiab + TotalEquity,
			    OB_Map <> -1,                             OB_Val,
			    GL_Val <> 0,                              GL_Val,
			    BLANK()
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\Statement Columns
		lineageTag: dde4a652-064b-4969-af27-3b5779e9fa8f

	/// BS value prior year - responds to Year slicer
	measure BS_PriorYear =
			VAR SelYear      = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			VAR PrevYear     = SelYear - 1
			VAR YearEnd      = DATE(PrevYear, 12, 31)
			VAR rowLevel     = SELECTEDVALUE(BS_Structure[RowLevel],    "")
			VAR acctName     = SELECTEDVALUE(BS_Structure[AccountName], "")
			VAR TotalAssets   = CALCULATE([BS_TotalAssets],         ALL(Dim_Date), Dim_Date[Year] = PrevYear)
			VAR CurrAssets    = CALCULATE([BS_CurrentAssets],       ALL(Dim_Date), Dim_Date[Year] = PrevYear)
			VAR NonCurrAssets = CALCULATE([BS_NonCurrentAssets],    ALL(Dim_Date), Dim_Date[Year] = PrevYear)
			VAR TotalLiab     = CALCULATE([BS_TotalLiabilities],    ALL(Dim_Date), Dim_Date[Year] = PrevYear)
			VAR CurrLiab      = CALCULATE([BS_CurrentLiabilities],  ALL(Dim_Date), Dim_Date[Year] = PrevYear)
			VAR LTLiab        = CALCULATE([BS_LongTermLiabilities], ALL(Dim_Date), Dim_Date[Year] = PrevYear)
			VAR TotalEquity   = CALCULATE([BS_Equity],              ALL(Dim_Date), Dim_Date[Year] = PrevYear)
			VAR GL_Val        = ABS(CALCULATE(SUM(GL_Actual[Amount]), TREATAS({acctName}, Dim_Accounts[AccountName]), ALL(Dim_Date), Dim_Date[Year] <= PrevYear))
			VAR OB_Map        = SWITCH(acctName, "Cash", 110100, "Prepaid Expenses", 130100, "Machinery & Equipment", 140100, "Buildings", 140200, "Accum. Depreciation", 140300, "Bank Loans", 230100, "Lease Liabilities", 230200, "Share Capital", 310100, "Retained Earnings", 320100, "Current Year Result", 330100, -1)
			VAR OB_Val        = ABS(SUMX(FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] = YearEnd && Opening_Balances[OB_Account] = OB_Map), Opening_Balances[OB_Amount]))
			RETURN
			SWITCH(
			    TRUE(),
			    rowLevel IN {"Header", "GroupHeader"} || acctName = "", BLANK(),
			    acctName = "TOTAL ASSETS",               TotalAssets,
			    acctName = "Total Current Assets",        CurrAssets,
			    acctName = "Total Non-current Assets",    NonCurrAssets,
			    acctName = "TOTAL EQUITY",                TotalEquity,
			    acctName = "TOTAL LIABILITIES",           TotalLiab,
			    acctName = "Total Current Liabilities",   CurrLiab,
			    acctName = "Total Long-term Liabilities", LTLiab,
			    acctName = "TOTAL LIABILITIES + EQUITY",  TotalLiab + TotalEquity,
			    OB_Map <> -1,                             OB_Val,
			    GL_Val <> 0,                              GL_Val,
			    BLANK()
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\Statement Columns
		lineageTag: d31485fb-562b-44a2-b088-bd8f01ba7d54

	/// YoY variance absolute
	measure BS_YoY_Var =
			VAR curr = [BS_Selected]
			VAR prev = [BS_PriorYear]
			RETURN IF(NOT ISBLANK(curr) && NOT ISBLANK(prev), curr - prev, BLANK())
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Balance Sheet\Statement Columns
		lineageTag: 76fc707b-c5d6-498e-a1f3-889dad33a844

	/// YoY variance %
	measure BS_YoY_Var_Pct = DIVIDE([BS_YoY_Var], ABS([BS_PriorYear]), BLANK())
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Balance Sheet\Statement Columns
		lineageTag: c852245c-31d8-4d10-abf0-6acd48deb4e6

	/// Font color - blue theme (2026-07-07): detail rows soft grey-white #D9D9D9, group headers light blue #9DC3E6, bands/totals pure white.
	measure BS_FontColor =
			VAR rowLevel = SELECTEDVALUE(BS_Structure[RowLevel], "")
			RETURN
			SWITCH(
			    TRUE(),
			    rowLevel = "Spacer",      "#000000",
			    rowLevel = "Detail",      "#D9D9D9",
			    rowLevel = "GroupHeader", "#9DC3E6",
			    "#FFFFFF"
			)
		displayFolder: Balance Sheet\Formatting
		lineageTag: a90de82a-a63a-49d3-92fc-c5bf466ac26b
		dataCategory: WebURL

	/// Background color - blue theme (2026-07-07): section bands deep blue #0F4C81 (was red #C00000), detail rows near-black blue tint #141C24 (was grey #6E6E6E) for a quieter CFO look on the black canvas.
	measure BS_BackgroundColor =
			VAR rowLevel = SELECTEDVALUE(BS_Structure[RowLevel], "")
			RETURN
			SWITCH(
			    TRUE(),
			    rowLevel = "Header",      "#0F4C81",
			    rowLevel = "GroupHeader", "#1A2733",
			    rowLevel = "Detail",      "#141C24",
			    rowLevel = "Subtotal",    "#1E3448",
			    rowLevel = "Total",       "#0F4C81",
			    rowLevel = "GrandTotal",  "#0F4C81",
			    rowLevel = "Spacer",      "#000000",
			    "#141C24"
			)
		displayFolder: Balance Sheet\Formatting
		lineageTag: cb361d26-0745-4885-96dd-8987d5357750
		dataCategory: WebURL

	/// BS 2023 - headers return 0 to prevent row suppression, formatted as blank. FIXED: Accounts Receivable and Inventory now use the OB-anchored CF_AsOf_* measures instead of the stale cumulative-since-inception GL_Val fallback.
	measure BS_2023 =
			VAR SelYear = 2023
			VAR YearEnd = DATE(SelYear, 12, 31)
			VAR rowLevel = SELECTEDVALUE(BS_Structure[RowLevel], "")
			VAR acctName = SELECTEDVALUE(BS_Structure[AccountName], "")
			VAR TotalAssets   = CALCULATE([BS_TotalAssets],         ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR CurrAssets    = CALCULATE([BS_CurrentAssets],       ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR NonCurrAssets = CALCULATE([BS_NonCurrentAssets],    ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR TotalLiab     = CALCULATE([BS_TotalLiabilities],    ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR CurrLiab      = CALCULATE([BS_CurrentLiabilities],  ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR LTLiab        = CALCULATE([BS_LongTermLiabilities], ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR TotalEquity   = CALCULATE([BS_Equity],              ALL(Dim_Date), Dim_Date[Year] = SelYear)
			VAR AR_Val        = ABS(CALCULATE([CF_AsOf_AccountsReceivable], ALL(Dim_Date), Dim_Date[Year] = SelYear))
			VAR Inv_Val       = ABS(CALCULATE([CF_AsOf_Inventory],          ALL(Dim_Date), Dim_Date[Year] = SelYear))
			VAR GL_Val = ABS(CALCULATE(SUM(GL_Actual[Amount]), TREATAS({acctName}, Dim_Accounts[AccountName]), ALL(Dim_Date), Dim_Date[Year] <= SelYear))
			VAR OB_Map = SWITCH(acctName, "Cash", 110100, "Prepaid Expenses", 130100, "Machinery & Equipment", 140100, "Buildings", 140200, "Accum. Depreciation", 140300, "Bank Loans", 230100, "Lease Liabilities", 230200, "Share Capital", 310100, "Retained Earnings", 320100, "Current Year Result", 330100, -1)
			VAR OB_Val = ABS(SUMX(FILTER(ALL(Opening_Balances), Opening_Balances[OB_Date] = YearEnd && Opening_Balances[OB_Account] = OB_Map), Opening_Balances[OB_Amount]))
			RETURN
			SWITCH(
			    TRUE(),
			    rowLevel IN {"Header", "GroupHeader", "Spacer"}, 0,
			    acctName = "TOTAL ASSETS",               TotalAssets,
			    acctName = "Total Current Assets",        CurrAssets,
			    acctName = "Total Non-current Assets",    NonCurrAssets,
			    acctName = "TOTAL EQUITY",                TotalEquity,
			    acctName = "TOTAL LIABILITIES",           TotalLiab,
			    acctName = "Total Current Liabilities",   CurrLiab,
			    acctName = "Total Long-term Liabilities", LTLiab,
			    acctName = "TOTAL LIABILITIES + EQUITY",  TotalLiab + TotalEquity,
			    acctName = "Accounts Receivable",         AR_Val,
			    acctName = "Inventory",                   Inv_Val,
			    OB_Map <> -1,                             OB_Val,
			    GL_Val <> 0,                              GL_Val,
			    BLANK()
			)
		formatString: #,0;-#,0;""
		displayFolder: Balance Sheet\Statement Columns
		lineageTag: e9ce345a-29ce-46a9-ab84-0f89d51e7426

