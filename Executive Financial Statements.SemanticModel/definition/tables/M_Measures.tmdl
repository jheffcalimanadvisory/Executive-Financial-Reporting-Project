	/// YoY Change % - 2026 vs 2025, red/green via BS_FontColor
	measure BS_YoY_Change =
			VAR curr = [BS_2026]
			VAR prev = [BS_2025]
			VAR chg  = DIVIDE(curr - prev, ABS(prev), BLANK())
			RETURN IF(NOT ISBLANK(curr) && NOT ISBLANK(prev), chg, BLANK())
		formatString: +0.0%;-0.0%;-
		displayFolder: Balance Sheet\Statement Columns
		lineageTag: 0cfe0fdd-050d-4d81-a01c-410011138749

	/// YoY font color - variance semantics kept (green positive / red negative, brightened for dark background); header/group rows match their band color so no stray text shows. Blue theme 2026-07-07.
	measure BS_YoY_FontColor =
			VAR rowLevel = SELECTEDVALUE(BS_Structure[RowLevel], "")
			VAR chg      = [BS_YoY_Change]
			RETURN
			SWITCH(
			    TRUE(),
			    rowLevel = "Header",      "#0F4C81",
			    rowLevel = "GroupHeader", "#1A2733",
			    rowLevel = "Spacer",      "#000000",
			    ISBLANK(chg),  "#141C24",
			    chg > 0,       "#6BCB77",
			    chg < 0,       "#FF6B6B",
			    "#FFFFFF"
			)
		displayFolder: Balance Sheet\Formatting
		lineageTag: 6fdeaaef-a67a-46e1-8d21-56538f154fe5

	/// EBIT Margin %
	measure IS_EBITMargin = DIVIDE([EBIT], [Revenue], BLANK())
		formatString: 0.0%
		displayFolder: Income Statement\Margins
		lineageTag: 8aa31bf5-a798-43a8-b93d-b106bee51055

	/// EBT = EBIT + Financial Result
	measure IS_EBT = [EBIT] + CALCULATE([Actual], Dim_Accounts[FSGroup] = "Financial Result")
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: 2cc43e12-448a-48e5-bcb9-57d09f01b3ff

	/// EBT Margin %
	measure IS_EBTMargin = DIVIDE([IS_EBT], [Revenue], BLANK())
		formatString: 0.0%
		displayFolder: Income Statement\Margins
		lineageTag: b4d2a615-226a-46b8-ba6a-0a3a4e612022

	/// COGS total
	measure IS_COGS = CALCULATE([Actual], Dim_Accounts[FSGroup] = "COGS")
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: 0054adf5-f852-4f11-8b65-50881cc4a31e

	/// OPEX total
	measure IS_OPEX = CALCULATE([Actual], Dim_Accounts[FSGroup] = "Operating Expenses")
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: 14b8c123-3094-48eb-b057-88f43e8c3000

	/// D&A total
	measure IS_DA = CALCULATE([Actual], Dim_Accounts[FSGroup] = "D&A")
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: 3efd3c50-bbb7-4fee-a6e1-893e9e342670

	/// Financial Result total
	measure IS_FinancialResult = CALCULATE([Actual], Dim_Accounts[FSGroup] = "Financial Result")
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: d5763e66-2289-46d5-b2ea-34b7bd7e702e

	/// Taxes total
	measure IS_Taxes = CALCULATE([Actual], Dim_Accounts[FSGroup] = "Taxes")
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: 539acae5-4af2-4184-8f07-452110a1e693

	/// Budget for Revenue only
	measure IS_RevenueBudget = CALCULATE([Budget], Dim_Accounts[FSGroup] = "Revenue")
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: 237a8f64-2f11-4001-80c4-5708f62ac55a

	/// Revenue variance vs budget absolute
	measure IS_RevenueVAR = [Revenue] - [IS_RevenueBudget]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: 05aec4c5-12a6-483c-b955-7b346bcc24f7

	/// Revenue variance vs budget %
	measure IS_RevenueVAR_Pct = DIVIDE([IS_RevenueVAR], ABS([IS_RevenueBudget]), BLANK())
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Income Statement
		lineageTag: ac2b9dac-081f-4c59-bfe2-b3da9b54d3a2

	/// Gross Margin % explicit
	measure IS_GrossMargin_Pct = DIVIDE([Gross Profit], [Revenue], BLANK())
		formatString: 0.0%
		displayFolder: Income Statement\Margins
		lineageTag: 13b68eac-211f-434e-9eaf-a306a9d57cd6

	/// IS Budget value — mirrors FS Report Value but from Budget
	measure IS_FSBudget =
			VAR CurrentFS  = SELECTEDVALUE(INCOME_Structure[FSGroup])
			VAR CurrentSub = SELECTEDVALUE(INCOME_Structure[FSSubgroup])
			VAR BudRev    = CALCULATE([Budget], Dim_Accounts[FSGroup] = "Revenue")
			VAR BudCOGS   = CALCULATE([Budget], Dim_Accounts[FSGroup] = "COGS")
			VAR BudOPEX   = CALCULATE([Budget], Dim_Accounts[FSGroup] = "Operating Expenses")
			VAR BudDA     = CALCULATE([Budget], Dim_Accounts[FSGroup] = "D&A")
			VAR BudFin    = CALCULATE([Budget], Dim_Accounts[FSGroup] = "Financial Result")
			VAR BudTaxes  = CALCULATE([Budget], Dim_Accounts[FSGroup] = "Taxes")
			VAR BudGP     = BudRev - BudCOGS
			VAR BudEBITDA = BudGP - BudOPEX
			VAR BudEBIT   = BudEBITDA - BudDA
			VAR BudNI     = BudEBIT + BudFin - BudTaxes
			RETURN
			SWITCH(
			    TRUE(),
			    CurrentFS = "Gross Profit", BudGP,
			    CurrentFS = "EBITDA",       BudEBITDA,
			    CurrentFS = "EBIT",         BudEBIT,
			    CurrentFS = "Net Income",   BudNI,
			    CALCULATE([Budget], TREATAS({CurrentFS}, Dim_Accounts[FSGroup]), TREATAS({CurrentSub}, Dim_Accounts[FSSubgroup]))
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: 967e771b-17ee-459a-8cc7-e27f6c648282

	/// IS Variance = Actual - Budget (FS context-aware)
	measure IS_FSVariance = [FS Report Value] - [IS_FSBudget]
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: 4a9b09ef-2b5b-4bb3-90b2-7f613bd0a581

	/// IS Variance % = Variance / ABS(Budget)
	measure IS_FSVariance_Pct = DIVIDE([IS_FSVariance], ABS([IS_FSBudget]), BLANK())
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Income Statement
		lineageTag: 42dc3615-c973-4359-bc7a-7d3bb1a8b43f

	/// Background color for IS matrix rows
	measure IS_BgColor =
			VAR fsGroup = SELECTEDVALUE(INCOME_Structure[FSGroup], "")
			RETURN
			SWITCH(
			    TRUE(),
			    fsGroup = "Net Income",                                                           "#C00000",
			    fsGroup IN {"Gross Profit", "EBITDA", "EBIT"},                                    "#6B0000",
			    fsGroup IN {"Revenue", "COGS", "Operating Expenses", "D&A", "Financial Result", "Taxes"} && ISBLANK(SELECTEDVALUE(INCOME_Structure[FSSubgroup])), "#C00000",
			    "#1A1A1A"
			)
		displayFolder: Income Statement\Formatting
		lineageTag: ed897ebe-a877-4c98-bbba-ec98d9ed5e3a

	/// Var% font color — green positive, red negative
	measure IS_VarColor =
			VAR rowLevel = SELECTEDVALUE(INCOME_Structure[RowLevel], "")
			VAR v = [IS_Var_Pct]
			RETURN
			IF(
			    rowLevel = "Margin" || ISBLANK(v), "#FFFFFF",
			    IF(v >= 0, "#4CAF50", "#FF4444")
			)
		displayFolder: Income Statement\Formatting
		lineageTag: 83578dd7-0017-4eb0-88fd-c58559917dca

	/// OPEX value for donut chart - filtered by FSSubgroup context
	measure IS_OPEX_Donut =
			CALCULATE(
			    [Actual],
			    Dim_Accounts[FSGroup] = "Operating Expenses",
			    TREATAS(
			        VALUES(INCOME_Structure[FSSubgroup]),
			        Dim_Accounts[FSSubgroup]
			    )
			)
		formatString: "€" #,0;-"€" #,0;"€" #,0
		displayFolder: Income Statement
		lineageTag: eeaab0fe-2ade-4a7d-a457-a0caa3baccdd

	/// IS Jan Actual
	measure IS_Jan =
			VAR yr = SELECTEDVALUE(Dim_Date[Year], MAX(Dim_Date[Year]))
			VAR fsGroup  = SELECTEDVALUE(INCOME_Structure[FSGroup],  "")
			VAR fsSub    = SELECTEDVALUE(INCOME_Structure[FSSubgroup],"")
			VAR rowLevel = SELECTEDVALUE(INCOME_Structure[RowLevel],  "")
			VAR vRev    = CALCULATE([Actual], Dim_Accounts[FSGroup]="Revenue",            ALL(Dim_Date), Dim_Date[Year]=yr, Dim_Date[Month Number]=1)
			VAR vCOGS   = CALCULATE([Actual], Dim_Accounts[FSGroup]="COGS",               ALL(Dim_Date), Dim_Date[Year]=yr, Dim_Date[Month Number]=1)
			VAR vOPEX   = CALCULATE([Actual], Dim_Accounts[FSGroup]="Operating Expenses", ALL(Dim_Date), Dim_Date[Year]=yr, Dim_Date[Month Number]=1)
			VAR vDA     = CALCULATE([Actual], Dim_Accounts[FSGroup]="D&A",                ALL(Dim_Date), Dim_Date[Year]=yr, Dim_Date[Month Number]=1)
			VAR vFin    = CALCULATE([Actual], Dim_Accounts[FSGroup]="Financial Result",   ALL(Dim_Date), Dim_Date[Year]=yr, Dim_Date[Month Number]=1)
			VAR vTax    = CALCULATE([Actual], Dim_Accounts[FSGroup]="Taxes",              ALL(Dim_Date), Dim_Date[Year]=yr, Dim_Date[Month Number]=1)
			VAR vGP=vRev-vCOGS  VAR vEB=vGP-vOPEX  VAR vET=vEB-vDA  VAR vBT=vET+vFin  VAR vNI=vBT-vTax
			VAR vSub=CALCULATE([Actual], Dim_Accounts[FSGroup]=fsGroup, Dim_Accounts[FSSubgroup]=fsSub, ALL(Dim_Date), Dim_Date[Year]=yr, Dim_Date[Month Number]=1)
			RETURN SWITCH(TRUE(), rowLevel IN {"Header","Margin"}, 0, fsGroup="Revenue" && rowLevel="Detail", vRev, fsGroup="Net Revenue", vRev, fsGroup="COGS" && rowLevel="Detail", vCOGS, fsGroup="Gross Profit", vGP, fsGroup="Operating Expenses" && rowLevel="Detail", vSub, fsGroup="OPEX Total", vOPEX, fsGroup="EBITDA", vEB, fsGroup="D&A" && rowLevel="Detail", vDA, fsGroup="EBIT", vET, fsGroup="Financial Result" && rowLevel="Detail", vSub, fsGroup="EBT", vBT, fsGroup="Taxes" && rowLevel="Detail", vTax, fsGroup="Net Income", vNI, BLANK())
		formatString: #,0;-#,0;""
